<?php
/**
 * Hyvä Themes - https://hyva.io
 * Customized Layered Navigation - Horizontal Dropdown Style
 */

declare(strict_types=1);

use Hyva\Theme\Model\ViewModelRegistry;
use Hyva\Theme\ViewModel\HeroiconsOutline;
use Magento\Framework\Escaper;
use Magento\LayeredNavigation\Block\Navigation;

/** @var Navigation $block */
/** @var Escaper $escaper */
/** @var ViewModelRegistry $viewModels */

/** @var HeroiconsOutline $heroicons */
$heroicons = $viewModels->require(HeroiconsOutline::class);
?>
<?php if ($block->canShowBlock()): ?>
    <div
        x-data="initLayeredNavigation()"
        x-init="checkIsMobileResolution()"
        @resize.window.debounce="checkIsMobileResolution()"
        @visibilitychange.window.debounce="checkIsMobileResolution()"
        class="my-toolbar toolbar-products flex justify-between gap-2 items-center px-0 md:mb-0 relative "
        role="region"
        aria-label="<?= $escaper->escapeHtmlAttr(__('Product filters')) ?>"
    >
        <!-- Title for mobile -->
        <div class="hidden ">
            <button
                type="button"
                @click="blockOpen = !blockOpen"
                class="flex items-center justify-between w-full text-start gap-6 md:gap-4 lg:gap-6 cursor-pointer text-start font-normal w-full bg-white px-4 py-2 md:py-3 rounded-none"
                aria-controls="filters-content"
                :aria-expanded="blockOpen"
            >
                <span><?= $escaper->escapeHtml(__('Shop By')) ?></span>
                <span
                    class="py-1 px-1 bg-container-lighter text-black"
                    x-ref="LayeredNavigationMobileToggleIcon"
                >
                    <?= $heroicons->chevronDownHtml(
                        'transition-transform transform duration-300 ease-in-out',
                        24,
                        24,
                        [
                            ":class" => "{ 'rotate-180': blockOpen }",
                            "aria-hidden" => "true",
                            "focusable" => "false"
                        ]
                    ); ?>
                </span>
            </button>
        </div>

        <!-- Filters Container -->
        <div
            id="filters-content"
            class="pt-0 md:flex  md:gap-4 md:block"
            :class="{ '': !blockOpen && isMobile }"
        >
            <?= $block->getChildHtml('state') ?>
            <a href="#product-list" class="sr-only focus:not-sr-only gap-0 md:gap-4 lg:gap-6 cursor-pointer text-start font-normal border-container w-full bg-white px-4 py-3 rounded-none">
                <?= $escaper->escapeHtml(__('Skip to product list')) ?>
            </a>

            <?php foreach ($block->getFilters() as $filter): ?>
                <?php if ($filter->getItemsCount()): ?>
                    <?php
                        $filterName = $filter->getName();
                        $filterLabel = ($filterName == 'Category') ? 'Select Category' : $filterName;
                    ?>
                    <div
                        x-data="{ open: false }"
                        class="relative inline-block w-full mb-4 md:mb-0 md:w-auto"
                    >
                        <!-- Filter Button -->
                        <button
                            type="button"
                            @click="open = !open"
                            class="flex items-center justify-between w-full text-start gap-6 md:gap-4 lg:gap-6 cursor-pointer text-start font-normal w-full bg-white px-4 py-3 md:mt-0 rounded-none border md:border-0"
                            :aria-expanded="open"
                        >
                            <span><?= $escaper->escapeHtml(__($filterLabel)) ?></span>
                            <img src="<?= $this->getViewFileUrl('images/filter-arrow.png') ?>" alt="filter-arrow" class="md:h-3 md:w-3" />
                            <!-- <?= $heroicons->chevronDownHtml(
                                'w-4 h-4 ml-2 text-gray-600 transition-transform duration-200 ease-in-out',
                                16,
                                16,
                                [":class" => "{ 'rotate-180': open }"]
                            ); ?> -->
                        </button>

                        <!-- Dropdown -->
                        <div
                            x-show="open"
                            @click.away="open = false"
                            x-transition
                            class="absolute mt-2 w-full md:w-48 bg-white border border-gray-200 rounded-lg shadow-lg z-50 max-h-60 overflow-y-auto"
                        >
                            <?= /* @noEscape */ $block->getChildBlock('renderer')->setFilterTitle($filterName)->render($filter); ?>
                        </div>
                    </div>
                <?php endif; ?>
            <?php endforeach; ?>
        </div>
    </div>

    <script>
        function initLayeredNavigation() {
            return {
                isMobile: false,
                blockOpen: false,
                checkIsMobileResolution() {
                    const mobileElement = this.$refs.LayeredNavigationMobileToggleIcon;
                    this.isMobile = mobileElement
                        ? getComputedStyle(mobileElement).display !== "none"
                        : window.matchMedia('(max-width: 767px)').matches;
                }
            }
        }
    </script>
<?php endif; ?>
