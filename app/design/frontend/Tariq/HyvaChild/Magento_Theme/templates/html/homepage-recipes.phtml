<script>
function recipeSlider() {
    return {
        active: 0,
        total: <?php echo count($posts_video); ?>,

        startX: 0,
        endX: 0,

        init() {}, // No auto-slide

        touchStart(e) {
            this.startX = e.touches[0].clientX;
        },

        touchMove(e) {
            this.endX = e.touches[0].clientX;
        },

        touchEnd() {
            let diff = this.startX - this.endX;

            if (Math.abs(diff) > 60) {
                if (diff > 0 && this.active < this.total - 1) {
                    this.active++;
                } else if (diff < 0 && this.active > 0) {
                    this.active--;
                }
            }
        }
    }
}
</script>
