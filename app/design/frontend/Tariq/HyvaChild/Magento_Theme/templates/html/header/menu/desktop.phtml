<script>
function megaMenu<?= $uniqueId ?>() {
  return {
    activeId: null,
    rightAlignId: null,
    openMenu(id) {
      this.activeId = id;
      this.$nextTick(() => this.fixPosition(id));
    },
    closeMenu() { this.activeId = null; },
    fixPosition(id) {
      const menu = this.$refs[`menu_${id}`];
      if (!menu) return;
      const rect = menu.getBoundingClientRect();
      const viewport = window.innerWidth || document.documentElement.clientWidth;
      this.rightAlignId = (rect.right > viewport - 20) ? id : null;
    }
  }
}
</script>
