/** @var ViewModelRegistry $viewModels */

$storeConfig = $viewModels->require(StoreConfig::class);
$maxItemsToDisplay = $storeConfig->getStoreConfig('checkout/sidebar/max_items_display_count');

/** @var HeroiconsOutline $heroicons */
$heroicons = $viewModels->require(HeroiconsOutline::class);
$custom = $viewModels->require(\Haartyhanks\RemoveObjectManager\ViewModel\Custom::class);
$quote = $custom->getQuote();
$couponCode = $quote->getCouponCode();
$subtotal = (float) $quote->getSubtotal();
$discount = abs((float) ($quote->getSubtotalWithDiscount() - $quote->getSubtotal()));
$shippingAmount = (float) $quote->getShippingAddress()->getShippingAmount();
$shippingDesc = $quote->getShippingAddress()->getShippingDescription();
$grandTotal = (float) $quote->getGrandTotal();

$cartTotalAfterDiscount = $subtotal - $discount;
if ($cartTotalAfterDiscount >= 100) {
    $shippingDesc = 'Free Delivery - Applicable for orders above £100';
    $shippingAmount = 0.00;
} else {
    $shippingDesc = 'Mainland UK - Orders Below £100';
    $shippingAmount = 9.99;
}
$grandTotal = $cartTotalAfterDiscount + $shippingAmount;

?>
<script>
    function initCartDrawer() {
        return {
            open: false,
            isLoading: false,
            cart: {},
            maxItemsToDisplay: <?= (int) $maxItemsToDisplay ?>,
            itemsCount: 0,
            cartItems: [],

            getData(data) {
                if (data.cart) {
                    this.cart = data.cart;
                    this.itemsCount = data.cart.items?.length || 0;
                    this.setCartItems();
                }
                this.isLoading = false;
            },

            getItemCountTitle() {
                return hyva.strf('<?= $escaper->escapeJs(__('%0 of %1 products in cart displayed')) ?>',
                    this.maxItemsToDisplay,
                    this.itemsCount
                );
            },

            setCartItems() {
                this.cartItems = this.cart.items?.sort((a, b) => b.item_id - a.item_id) || [];
                if (this.maxItemsToDisplay > 0) {
                    this.cartItems = this.cartItems.slice(0, this.maxItemsToDisplay);
                }
            },

            increaseQty(item) {
                let qty = parseInt(item.qty, 10) || 0;
                item.qty = qty + 1;
                this.updateItemQty(item);
                 window.location.reload();
            },
         decreaseQty(item) {
        let qty = parseInt(item.qty, 10) || 1;
         if (qty <= 1) {
        return;
       }

    // qty > 1
    item.qty = qty - 1;
    this.updateItemQty(item);

    window.location.reload();
},



            updateItemQty(item) {
                this.isLoading = true;
                const formKey = hyva.getFormKey();
                const postUrl = BASE_URL + 'checkout/sidebar/updateItemQty/';
                const body = `form_key=${formKey}&item_id=${item.item_id}&item_qty=${item.qty}`;

                fetch(postUrl, {
                    method: "POST",
                    headers: { "content-type": "application/x-www-form-urlencoded; charset=UTF-8" },
                    body: body,
                    credentials: "include"
                })
                .then(res => res.json())
                .then(result => {
                    if (result.success) {
                        window.dispatchEvent(new CustomEvent('reload-customer-section-data'));
                    } else {
                        window.dispatchMessages && window.dispatchMessages([{
                            type: 'error',
                            text: result.error_message || '<?= $escaper->escapeJs(__('Unable to update quantity.')) ?>'
                        }]);
                    }
                })
                .catch(() => {
                    window.dispatchMessages && window.dispatchMessages([{
                        type: 'error',
                        text: '<?= $escaper->escapeJs(__('Something went wrong updating quantity.')) ?>'
                    }]);
                })
                .finally(() => {
                    this.isLoading = false;
                });
            },

            deleteItemFromCart(itemId) {
                this.isLoading = true;
                const formKey = hyva.getFormKey();
                const postUrl = BASE_URL + 'checkout/sidebar/removeItem/';

                fetch(postUrl, {
                    headers: { "content-type": "application/x-www-form-urlencoded; charset=UTF-8" },
                    body: "form_key=" + formKey + "&item_id=" + itemId,
                    method: "POST",
                    credentials: "include"
                })
                .then(res => res.json())
                .then(result => {
                    if (result.success) {
                        window.dispatchMessages && window.dispatchMessages([{
                            type: 'success',
                            text: '<?= $escaper->escapeJs(__('Item removed.')) ?>'
                        }]);
                        window.dispatchEvent(new CustomEvent('reload-customer-section-data'));
                    } else {
                        window.dispatchMessages && window.dispatchMessages([{
                            type: 'error',
                            text: result.error_message
                        }]);
                    }
                })
                .finally(() => {
                    this.isLoading = false;
                });
                 window.location.reload();
            },

            scrollLock(use = true) {
                document.body.style.overflow = use ? "hidden" : "";
            },

            toggleCartDrawer(event) {
                if (event.detail && event.detail.isOpen !== undefined) {
                    if (event.detail.isOpen) {
                        this.openCartDrawer();
                    } else {
                        this.open = false;
                        this.scrollLock(false);
                        this.$refs?.cartDialogContent && hyva.releaseFocus(this.$refs.cartDialogContent);
                    }
                } else {
                    this.openCartDrawer();
                }
            },

            openCartDrawer() {
                this.open = true;
                this.scrollLock(true);
                this.$nextTick(() => {
                    this.$refs?.cartDialogContent && hyva.trapFocus(this.$refs.cartDialogContent);
                });
            },

            closeCartDrawer() {
                this.$dispatch('toggle-cart', { isOpen: false });
            },

            getSectionDataExtraActions() {
                if (!this.cart.extra_actions) return '';
                const node = document.createElement('div');
                node.innerHTML = this.cart.extra_actions;
                hyva.activateScripts(node);
                return node.innerHTML;
            }
        }
    }
</script>

