<?php
if ($_SERVER['REQUEST_METHOD'] === 'POST' && isset($_POST['franchise_form'])) {
    $name = htmlspecialchars(trim($_POST['name']));
    $email = filter_var(trim($_POST['email']), FILTER_VALIDATE_EMAIL);
    $contact = htmlspecialchars(trim($_POST['contact']));

    if ($email) {
        $to = "franchise@tariqhalalmeats.com";
        $subject = "New Franchise Enquiry from";

        $headers = "MIME-Version: 1.0\r\n";
        $headers .= "Content-type:text/html; charset=UTF-8\r\n";
        $headers .= "From: Franchise Form <info@tariqhalalmeats.com>\r\n";
        $headers .= "Reply-To: {$email}\r\n";

        $message = "
            <html>
            <head><title>Franchise Enquiry</title></head>
            <body>
                <h2>Franchise Enquiry Received</h2>
                <p><strong>Name:</strong> {$name}</p>
                <p><strong>Email:</strong> {$email}</p>
                <p><strong>Contact Number:</strong> {$contact}</p>
            </body>
            </html>
        ";

        if (mail($to, $subject, $message, $headers)) {
            // Redirect without showing any message
            header("Location: /thank-you");
            exit;
        }
    }
}
?>

