use Magento\Catalog\Block\Product\ReviewRendererInterface;
use Magento\Catalog\Model\Product;
use Magento\Framework\App\Action\Action;
use Mageplaza\Blog\Block\Post\RelatedProduct;
use Magento\Framework\Escaper;

/** @var $block RelatedProduct */
/** @var Escaper $escaper */
$_productCollection = $block->getLoadedProductCollection();
$_helper = $block->getHelper();
?>
<?php if (!$_productCollection->count()): ?>
    <div class="message info empty">
        <div><?= $escaper->escapeHtml(
            __('We can\'t find products matching the selection.')
        ) ?></div>
    </div><?php
  
    else: ?>
    <?= $block->getToolbarHtml() ?>
    <?= $block->getAdditionalHtml() ?>
    <?php
    if ($block->getMode() == "grid") {
        $viewMode = "";
        $imageDisplayArea = "category_page_grid";
        $showDescription = false;
        $templateType = ReviewRendererInterface::SHORT_VIEW;
    } else {
        $viewMode = "list";
        $imageDisplayArea = "category_page_list";
        $showDescription = true;
        $templateType = ReviewRendererInterface::FULL_VIEW;
    }
    $pos = $block->getPositioned();
    $bestselling = $viewModels->require(
        \Haartyhanks\RemoveObjectManager\ViewModel\BestSellers::class
    );
    $formKey = $bestselling->getFormKey();
    $cartBlock = $block
        ->getLayout()
        ->createBlock(\Magento\Checkout\Block\Cart\Sidebar::class);
    $cartItems = $cartBlock ? $cartBlock->getItems() : [];
    ?>
    <div class="products wrapper <?= $viewMode ?> products-<?= $viewMode ?>">
        <?php if ($block->relatedMode() !== "1"): ?>
            <div class="products list items product-items mt-6 grid grid-cols-2 gap-4 md:grid-cols-3 lg:grid-cols-4">
                <?php
            /** @var Product $_product */
            ?>
                <?php foreach ($_productCollection as $_product): ?>
                    <div class="item product product-item">
                        <div class="product-item-info" data-container="product-<?= $viewMode ?>">
                            <?php
                            $productImage = $block->getImage(
                                $_product,
                                $imageDisplayArea
                            );
                            if ($pos != null) {
                                $position =
                                    ' style="left:' .
                                    $productImage->getWidth() .
                                    "px;" .
                                    "top:" .
                                    $productImage->getHeight() .
                                    'px;"';
                            }
                            ?>

                            <?php
                    // Product Image
                    ?>
                            

                            <a href="<?= $escaper->escapeUrl(
                                $block->getParentProductUrl($_product)
                            ) ?>"
                               class="product photo product-item-photo"
                               tabindex="-1">
                                <?= $productImage->toHtml() ?>
                            </a>
                            <div class="product details product-item-details">
                                <?php $_productNameStripped = $block->stripTags(
                                    $_product->getName(),
                                    null,
                                    true
                                ); ?>
                                <strong class="product name product-item-name">
                                    <a class="product-item-link"
                                       href="<?= $escaper->escapeUrl(
                                           $block->getParentProductUrl(
                                               $_product
                                           )
                                       ) ?>">
                                        <?= $_helper->productAttribute(
                                            $_product,
                                            $_product->getName(),
                                            "name"
                                        ) ?>
                                    </a>
                                </strong>
                                <?= $block->getReviewsSummaryHtml(
                                    $_product,
                                    $templateType
                                ) ?>
                                <?= $block->getProductPrice($_product) ?>
                                <?= $block->getProductDetailsHtml($_product) ?>
                                <div class="product-item-inner">
                                    <div class="product actions product-item-actions"
                                        <?= strpos(
                                            (string) $pos,
                                            $viewMode . "-actions"
                                        )
                                            ? $escaper->escapeHtmlAttr(
                                                $position
                                            )
                                            : "" ?>>
                                        <div class="actions-primary"
                                            <?= strpos(
                                                (string) $pos,
                                                $viewMode . "-primary"
                                            )
                                                ? $escaper->escapeHtmlAttr(
                                                    $position
                                                )
                                                : "" ?>>
                                            <?php if (
                                                $_product->isSaleable()
                                            ): ?>
                                                <?php $postParams = $block->getAddToCartPostParams(
                                                    $_product
                                                ); ?>
                                                <form data-role="tocart-form"
                                                      data-product-sku="<?= $escaper->escapeHtml(
                                                          $_product->getSku()
                                                      ) ?>"
                                                      action="<?= $escaper->escapeUrl(
                                                          $postParams["action"]
                                                      ) ?>"
                                                      method="post">
                                                    <input type="hidden" name="product"
                                                           value="<?= $postParams[
                                                               "data"
                                                           ]["product"] ?>">
                                                    <input type="hidden" name="<?= Action::PARAM_NAME_URL_ENCODED ?>"
                                                           value="<?= $postParams[
                                                               "data"
                                                           ][
                                                               Action
                                                                   ::PARAM_NAME_URL_ENCODED
                                                           ] ?>">
                                                    <?= $block->getBlockHtml(
                                                        "formkey"
                                                    ) ?>
                                                    <button type="submit"
                                                            title="<?= $escaper->escapeHtmlAttr(
                                                                __(
                                                                    "Add to Cart"
                                                                )
                                                            ) ?>"
                                                            class="action tocart btn btn-primary">
                                                        <span><?= $escaper->escapeHtml(
                                                            __("Add to Cart")
                                                        ) ?></span>
                                                    </button>
                                                </form>
                                            <?php else: ?>
                                                <?php if (
                                                    $_product->isAvailable()
                                                ): ?>
                                                    <div class="stock available">
                                                        <span><?= $escaper->escapeHtml(
                                                            __("In stock")
                                                        ) ?></span></div>
                                                <?php else: ?>
                                                    <div class="stock unavailable">
                                                        <span><?= $escaper->escapeHtml(
                                                            __("Out of stock")
                                                        ) ?></span></div>
                                                <?php endif; ?>
                                            <?php endif; ?>
                                        </div>
                                        <div data-role="add-to-links" class="actions-secondary"
                                            <?= strpos(
                                                (string) $pos,
                                                $viewMode . "-secondary"
                                            )
                                                ? $escaper->escapeHtmlAttr(
                                                    $position
                                                )
                                                : "" ?>>
                                            <?php if (
                                                $addToBlock = $block->getChildBlock(
                                                    "addto"
                                                )
                                            ): ?>
                                                <?= $addToBlock
                                                    ->setProduct($_product)
                                                    ->getChildHtml() ?>
                                            <?php endif; ?>
                                        </div>
                                    </div>
                                    <?php if ($showDescription): ?>
                                        <div class="product description product-item-description">
                                            <?= $_helper->productAttribute(
                                                $_product,
                                                $_product->getShortDescription(),
                                                "short_description"
                                            ) ?>
                                            <a href="<?= $escaper->escapeUrl(
                                                $block->getParentProductUrl(
                                                    $_product
                                                )
                                            ) ?>"
                                               title="<?= $_productNameStripped ?>"
                                               class="action more"><?= $escaper->escapeHtml(
                                                   __("Learn More")
                                               ) ?></a>
                                        </div>
                                    <?php endif; ?>
                                </div>
                            </div>
                        </div>
                    </div>
                <?php endforeach; ?>
            </div>
            <style>
                .page-products .product-item-info {
                    width: 220px;
                    padding: 20px;
                }

            </style>
        <?php else: ?>
            <div class="">
                <?php
            /** @var $_product Product */
            ?>
                <section id="products-carousel" class="splide" aria-label="Related Products">
                    <div class="splide__track">
                        <ul class="splide__list">
                            <?php foreach ($_productCollection as $_product):

                                $productInCart = 0;
                                $itemId = "null";
                                foreach ($cartItems as $item) {
                                    if (
                                        $item->getProductId() ==
                                        $_product->getId()
                                    ) {
                                        $productInCart = (int) $item->getQty();
                                        $itemId = $item->getItemId();
                                        break;
                                    }
                                }
                                ?>
                                <li class="splide__slide">
                                    <div class="item product product-item mp-blog-slider-item">
                                        <div class="product-item-info" data-container="product-<?= $viewMode ?>">
                                            <?php
                                            $productImage = $block->getImage(
                                                $_product,
                                                $imageDisplayArea
                                            );
                                            if ($pos != null) {
                                                $position =
                                                    ' style="left:' .
                                                    $productImage->getWidth() .
                                                    "px;" .
                                                    "top:" .
                                                    $productImage->getHeight() .
                                                    'px;"';
                                            }
                                            ?>
                                            <?php
                                            $specialPrice = $_product->getSpecialPrice();
                                            $regularPrice = $_product->getPrice();
                                            $specialFromDate = $_product->getSpecialFromDate();
                                            $specialToDate = $_product->getSpecialToDate();
                                            $todayDate = new \DateTime();
                                            $specialFrom = $specialFromDate
                                                ? new \DateTime(
                                                    $specialFromDate
                                                )
                                                : null;
                                            $specialTo = $specialToDate
                                                ? new \DateTime($specialToDate)
                                                : null;
                                            if (
                                                $specialPrice &&
                                                (!$specialFrom ||
                                                    $specialFrom <=
                                                        $todayDate) &&
                                                (!$specialTo ||
                                                    $specialTo >= $todayDate) &&
                                                $specialPrice < $regularPrice
                                            ) {
                                                $discount = round(
                                                    100 -
                                                        ($specialPrice /
                                                            $regularPrice) *
                                                            100
                                                );
                                                echo '<div class="discount-badge">' .
                                                    $discount .
                                                    "%<br>OFF</div>";
                                            }
                                            ?>

                                            <a href="<?= $escaper->escapeUrl(
                                                $block->getParentProductUrl(
                                                    $_product
                                                )
                                            ) ?>"
                                               class="product photo product-item-photo"
                                               tabindex="-1">
                                                <?= $productImage->toHtml() ?>
                                            </a>
                                            <div class="product details product-item-details">
                                                <?php $_productNameStripped = $block->stripTags(
                                                    $_product->getName(),
                                                    null,
                                                    true
                                                ); ?>
                                                <strong class="product name product-item-name">
                                                    <a class="product-item-link"
                                                       href="<?= $escaper->escapeUrl(
                                                           $block->getParentProductUrl(
                                                               $_product
                                                           )
                                                       ) ?>">
                                                        <?= $_helper->productAttribute(
                                                            $_product,
                                                            $_product->getName(),
                                                            "name"
                                                        ) ?>
                                                    </a>
                                                </strong>
                                                <?= $block->getReviewsSummaryHtml(
                                                    $_product,
                                                    $templateType
                                                ) ?>
                                                <?= $block->getProductPrice(
                                                    $_product
                                                ) ?>
                          <?php if ($_product->getWeight() != ""): ?>
                                 <div class="list-product-weight">
                         <?php
                           $value = (float) $_product->getWeight();
                         if ($value > 0) {
                           if (floor($value) == $value) {
                        echo "Weight " . number_format($value, 1, ".", "");
                          } else {
                          echo "Weight " .
                       rtrim(rtrim(number_format($value, 4, ".", ""), "0"), ".");
            }
        }
        ?>
    </div>
<?php endif; ?>

                                                <?= $block->getProductDetailsHtml(
                                                    $_product
                                                ) ?>
                                                  <?php $hasAnyOptions = $_product->getHasOptions(); ?>
         <div class="mt-3"
            x-data="customCart(
            <?= $_product->getId() ?>,
            '<?= $formKey ?>',
            <?= (int) $productInCart ?>,
            <?= $itemId !== "null" ? $itemId : "null" ?>
            )">
            <template x-if="<?= $hasAnyOptions ?>">
               <button type="button"
                  @click="window.location.href='<?= $escaper->escapeUrl(
                      $_product->getProductUrl()
                  ) ?>'"
                  class="w-full bg-blue-600 hover:bg-blue-700 text-white rounded-lg py-2 text-sm">
               Customise & Add to Basket
               </button>
            </template>
            <template x-if="<?= !$hasAnyOptions ?>">
               <div class="custom-cart-ui">
                  <template x-if="qty === 0">
                     <div class="cart-btn-wrapper">
                        <button @click="addToCart()" :disabled="loading"
                           class="w-full bg-blue-600 text-white rounded-lg py-2 text-sm">
                           <template x-if="!loading"><span>+ Add to Basket</span></template>
                           <template x-if="loading"><span>Adding...</span></template>
                        </button>
                     </div>
                  </template>
                  <template x-if="qty > 0">
                     <div class="qty-state flex items-center gap-2 justify-center">
                        <button @click="decrease()" :disabled="loading" class="bg-gray-200 px-2 py-1 rounded">-</button>
                        <span x-text="qty + ' Added'" class="text-sm font-medium text-gray-900"></span>
                        <button @click="increase()" :disabled="loading" class="bg-gray-200 px-2 py-1 rounded">+</button>
                     </div>
                  </template>
               </div>
            </template>
         </div>
                                            </div>
                                        </div>
                                    </div>
                                </li>
                            <?php
                            endforeach; ?>
                        </ul>
                    </div>
                </section>
            </div>
            <script>
                document.addEventListener('DOMContentLoaded', function () {
                    new Splide('#products-carousel', {
                        arrows: false,
                       //pagination: false,
                        perPage: 4,
                        breakpoints: {
                            1028: {
                                perPage: 2
                            }
                        }
                    }).mount();
                });
            </script>
        <?php endif; ?>
    </div>
    <?= $block->getToolbarHtml() ?>
    <?php if (!$block->isRedirectToCartEnabled()): ?>
        <script type="text/x-magento-init">
            {
                "[data-role=tocart-form], .form.map.checkout": {
                    "catalogAddToCart": {
                        "product_sku": "<?= $escaper->escapeJs(
                            $_product->getSku()
                        ) ?>"
                    }
                }
            }

        </script>
    <?php endif; ?>
<?php endif; ?>
