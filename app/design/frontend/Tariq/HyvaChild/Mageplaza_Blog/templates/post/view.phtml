 <script type="text/javascript">
    require(['jquery', 'Magento_Customer/js/customer-data'], function ($, customerData) {
        window.initCustomCartUI = function (context) {
            const container = context || $(document);

            container.find('.custom-cart-ui').each(function () {
                const wrapper = $(this);
                const productId = wrapper.data('product-id');
                const formKey = wrapper.data('form-key');
                let qty = 0;
                let itemId = null;

                const $defaultState = wrapper.find('.default-state');
                const $qtyState = wrapper.find('.qty-state');
                const $qtyText = wrapper.find('.qty-text');

                function showQtyUI(q) {
                    $defaultState.hide();
                    $qtyState.show();
                    $qtyText.text(q + ' Added');
                }

                function showDefaultUI() {
                    $defaultState.show();
                    $qtyState.hide();
                }

                function reloadCartData(callback) {
                    customerData.invalidate(['cart']);
                    customerData.reload(['cart'], true).done(function () {
                        const cart = customerData.get('cart')();
                        const item = cart.items.find(i => i.product_id == productId);

                        if (item) {
                            qty = parseInt(item.qty);
                            itemId = item.item_id;
                            showQtyUI(qty);
                        } else {
                            qty = 0;
                            itemId = null;
                            showDefaultUI(); 
                        }

                        if (typeof callback === 'function') callback();
                    });
                }

                function updateQty(newQty) {
                    if (!itemId) return;

                    if (newQty <= 0) {
                        $.ajax({
                            url: BASE_URL + 'checkout/cart/delete/id/' + itemId,
                            type: 'POST',
                            data: { form_key: formKey },
                            success: function () {
                                qty = 0;
                                itemId = null;
                                showDefaultUI();
                                reloadCartData();
                            }
                        });
                    } else {
                        $.post(BASE_URL + 'checkout/sidebar/updateItemQty', {
                            item_id: itemId,
                            item_qty: newQty,
                            form_key: formKey
                        }, function () {
                            reloadCartData();
                        });
                    }
                }

                function addToCart() {
                    $.post(BASE_URL + 'checkout/cart/add', {
                        product: productId,
                        qty: 1,
                        form_key: formKey
                    }, function () {
                        reloadCartData();
                    });
                }

                wrapper.find('.btn-add-to-cart').off('click').on('click', function (e) {
                    e.preventDefault();
                    addToCart();
                });

                wrapper.find('.btn-increase').off('click').on('click', function () {
                    if (qty >= 1 && itemId) {
                        updateQty(qty + 1);
                    }
                });

                wrapper.find('.btn-decrease').off('click').on('click', function () {
                    if (qty > 1 && itemId) {
                        updateQty(qty - 1);
                    } else if (qty === 1 && itemId) {
                        updateQty(0);
                    }
                });

                // Initial check
                const cart = customerData.get('cart')();
                if (cart && cart.items) {
                    const item = cart.items.find(i => i.product_id == productId);
                    if (item) {
                        qty = parseInt(item.qty);
                        itemId = item.item_id;
                        showQtyUI(qty);
                    } else {
                        showDefaultUI(); 
                    }
                }
            });
        };
        $(document).ready(function () {
            initCustomCartUI($(document));
        });
        customerData.get('cart').subscribe(function () {
            initCustomCartUI($(document));
        });
    });
</script>

