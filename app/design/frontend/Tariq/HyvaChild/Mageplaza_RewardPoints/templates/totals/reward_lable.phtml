<script>
// Single helper to format reward points safely
window.mpFormatReward = function (value) {
    try {
        if (typeof rewardPoints === 'function') {
            return rewardPoints().format(value);
        }
    } catch (e) {return 0}
    return value;
};
</script>

<!-- display subtotal including and excluding tax -->
<template x-if="segment.code === 'mp_reward_earn' && 'both' === checkoutConfig.reviewTotalsDisplayMode && segment.value > 0">
    <div class="flex pb-2 my-2 border-b text-md lg:text-sm md:grid md:grid-cols-2 md:w-full border-container">
        <div class="w-7/12 text-left md:w-auto"
             x-html="`${segment.title}` "
        ></div>
        <div class="w-5/12 text-right md:w-auto">
            <span class="price mp-rw-highlight" x-text="mpFormatReward(segment.value)" style="font-weight: bold;"></span>
        </div>
    </div>
</template>
