use Magento\Framework\Escaper;
use Magento\Framework\View\Element\Template;
use Hyva\Checkout\ViewModel\Checkout\Formatter as FormatterViewModel;
use Hyva\Theme\Model\ViewModelRegistry;
use Hyva\Checkout\ViewModel\Checkout\PriceSummary\TotalSegments as TotalSegmentsViewModel;
use Mageplaza\RewardPoints\Helper\Point;

/** @var Template $block */
/** @var FormatterViewModel $formatterViewModel */
/** @var ViewModelRegistry $viewModels */
/** @var Escaper $escaper */
/** @var TotalSegmentsViewModel $totalSegmentsViewModel */

$formatterViewModel     = $viewModels->require(FormatterViewModel::class);
$totalSegmentsViewModel = $viewModels->require(TotalSegmentsViewModel::class);
$totalSegments          = $totalSegmentsViewModel->getTotals()->getTotalSegments();
$rewardSpent            = isset($totalSegments['mp_reward_spent']) ? $totalSegments['mp_reward_spent']->getValue() : null;
$segment                = $block->getSegment();
$rewardPointsData       = $block->getRewardPointsData();

$isShow = false;
if ($rewardPointsData) {
    if((int) $rewardPointsData['balance'] == 0) {
        $isShow = true;
    }
    if(isset($rewardPointsData['spending']['earnWithSpent'])) {
        $earnWithSpent = $rewardPointsData['spending']['earnWithSpent'];
        if ($earnWithSpent === true || ($earnWithSpent === false && $rewardSpent === null)) {
            $isShow = true;
        }
    } else {
        $isShow = true;
    }
}
$pointHelper      = $this->helper(Point::class);
$pluralPointLabel = $pointHelper->getPluralPointLabel();
?>
<?php if ($isShow): ?>
    <div class="flex gap-4 justify-between text-slate-800 text-base md:gap-0" id="mp_reward_earn">
        <span class="label">
            <?= $escaper->escapeHtml(array_key_exists('title', $segment)
                ? __($segment['title'])
                : __('You will earn')) ?>
        </span>
        <span class="value font-bold">
            <?= /* @noEscape */ $pointHelper->format($segment['value']) ?>
        </span>
    </div>
<?php endif; ?>
