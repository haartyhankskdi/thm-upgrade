<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <update handle="customer_account"/>
    <update handle="hyva_form_validation"/>
    <head>
        <title>Account Information</title>
    </head>

         <referenceBlock name="breadcrumbs">
    <action method="addCrumb">
        <argument name="crumbName" xsi:type="string">Home</argument>
        <argument name="crumbInfo" xsi:type="array">
            <item name="title" xsi:type="string">Home</item>
            <item name="label" xsi:type="string">Home</item>
            <item name="link" xsi:type="string">{{baseUrl}}</item>
        </argument>
    </action>
    <action method="addCrumb">
        <argument name="crumbName" xsi:type="string">Account Information</argument>
        <argument name="crumbInfo" xsi:type="array">
            <item name="title" xsi:type="string">Account Information</item>
            <item name="label" xsi:type="string">Account Information</item>
        </argument>
    </action>
</referenceBlock>
<referenceBlock name="page.main.title">
            <action method="setPageTitle">
                <argument translate="true" name="title" xsi:type="string">Account Information</argument>
            </action>
        </referenceBlock>
    <body>
        <referenceContainer name="content">
            <block class="Magento\Customer\Block\Form\Edit" name="customer_edit" template="Magento_Customer::form/edit.phtml" cacheable="false">
                <container name="form.additional.info" as="form_additional_info"/>
                <container name="fieldset.edit.info.additional" as="fieldset_edit_info_additional"/>
            </block>
        </referenceContainer>
        <referenceContainer name="before.body.end">
            <block name="password.validate.js" template="Magento_Customer::js/password-validation.phtml"/>
        </referenceContainer>
    </body>
</page>
