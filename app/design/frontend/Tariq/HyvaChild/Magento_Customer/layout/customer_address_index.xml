<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <update handle="customer_account"/>
         <referenceBlock name="breadcrumbs">
    <action method="addCrumb">
        <argument name="crumbName" xsi:type="string">Home</argument>
        <argument name="crumbInfo" xsi:type="array">
            <item name="title" xsi:type="string">Home</item>
            <item name="label" xsi:type="string">Home</item>
            <item name="link" xsi:type="string">{{baseUrl}}</item>
        </argument>
    </action>
    <action method="addCrumb">
        <argument name="crumbName" xsi:type="string">Address Book</argument>
        <argument name="crumbInfo" xsi:type="array">
            <item name="title" xsi:type="string">Address Book</item>
            <item name="label" xsi:type="string">Address Book</item>
        </argument>
    </action>
</referenceBlock>

    <body>
        <referenceContainer name="content">
            <block class="Magento\Customer\Block\Address\Book" name="address_book"
                   template="Magento_Customer::address/book.phtml" cacheable="false"/>
            <block class="Magento\Customer\Block\Address\Grid" name="address_grid"
                   template="Magento_Customer::address/grid.phtml" cacheable="false"/>
        </referenceContainer>
    </body>
</page>
