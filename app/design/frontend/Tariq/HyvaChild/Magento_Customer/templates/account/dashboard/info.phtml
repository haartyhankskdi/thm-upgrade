<?php
function card($url, $img, $label, $delete = false) {
    $textClass = $delete ? "text-red-600" : "text-gray-800";

    if ($delete) {
        echo '
        <div x-data="{ open: false }">
            <a href="javascript:void(0)" x-on:click="open = true" class="block">
                <div class="py-12 bg-[#F5F9F7] rounded hover:shadow-lg transition cursor-pointer">
                    <div class="flex flex-col items-center gap-4 mb-6">
                        <img src="'.$img.'" class="w-12 h-12" />
                        <h3 class="text-xl font-medium '.$textClass.'">'.$label.'</h3>
                    </div>
                </div>
            </a>

            <!-- DELETE POPUP -->
            <div x-show="open" x-cloak
                 class="fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center">
                <div class="bg-white rounded-lg p-6 w-96 text-center">
                    <h2 class="text-lg font-semibold text-red-600 mb-4">
                        Delete Account
                    </h2>

                    <p class="text-gray-700 mb-6">
                        Are you sure you want to delete your account?
                    </p>

                    <div class="flex justify-center gap-4">
                        <button type="button"
                                x-on:click="open = false"
                                class="px-4 py-2 border rounded">
                            Cancel
                        </button>

                        <a href="'.$url.'"
                           class="px-4 py-2 bg-red-600 text-white rounded">
                            Yes, Delete
                        </a>
                    </div>
                </div>
            </div>
        </div>';
    } else {
        echo '
        <a href="'.$url.'" class="block">
            <div class="py-12 bg-[#F5F9F7] rounded hover:shadow-lg transition cursor-pointer">
                <div class="flex flex-col items-center gap-4 mb-6">
                    <img src="'.$img.'" class="w-12 h-12" />
                    <h3 class="text-xl font-medium '.$textClass.'">'.$label.'</h3>
                </div>
            </div>
        </a>';
    }
}
?>

