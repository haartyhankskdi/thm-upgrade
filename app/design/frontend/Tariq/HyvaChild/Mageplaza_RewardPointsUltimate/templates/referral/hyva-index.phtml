<script>
    function rewardRefer() {
        return {
            id: null,
            copiedText: '',
            sendBy: function (id) {
                this.isDisplayInviteMessage(id);
            },
            changeText: function (e) {
                const inputElement = e.currentTarget.parentElement.querySelector('input');
                inputElement.select();
                document.execCommand('copy');

                return e.currentTarget.innerText = '<?= $block->escapeHtml(__('copied')) ?>';
            },
            hoverText: function (e) {
                if (e) {
                    return e.currentTarget.innerText = '<?= $block->escapeHtml(__('copy')) ?>';
                }

                return '<?= $block->escapeHtml(__('copy')) ?>';
            },
            isDisplayInviteMessage: function (id) {
                if (id === 'store') {
                    this.id = null;
                } else {
                    this.id = id;
                }
            },
        }
    }
</script>
