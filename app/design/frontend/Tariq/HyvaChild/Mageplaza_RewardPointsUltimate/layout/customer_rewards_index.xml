<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" layout="2columns-left" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <css src="Mageplaza_Core::css/grid-mageplaza.css"/>
        <css src="Mageplaza_RewardPointsUltimate::css/style.css"/>
        <css src="https://use.fontawesome.com/releases/v6.3.0/css/all.css" src_type="url"/>
    </head>
    <body>
        <referenceBlock name="page.main.title" remove="true"/>
        <referenceBlock name="reward_dashboard">
            <block class="Mageplaza\RewardPointsUltimate\Block\Account\TierDashboard" name="mp_rw_das_tier_dashboard"
                   template="Mageplaza_RewardPointsUltimate::account/dashboard.phtml" before="reward_dashboard_transaction" ifconfig="rewardpoints/milestone/enabled">
                <block class="Mageplaza\RewardPointsUltimate\Block\Milestone\Tier" name="mp_reward_das_tier"
                       template="Mageplaza_RewardPointsUltimate::account/milestone/range.phtml" cacheable="false">
                </block>
            </block>
        </referenceBlock>
    </body>
</page>
