<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" layout="2columns-left" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <update handle="rewards_account"/>
    <head>
        <css src="Mageplaza_Core::css/grid-mageplaza.css"/>
        <css src="Mageplaza_RewardPointsUltimate::css/style.css"/>
    </head>
    <body>
        <referenceBlock name="page.main.title" remove="true"/>
        <referenceBlock name ="sidebar.main.reward_nav">
            <arguments>
                <argument name="block_title" translate="true" xsi:type="string">My Referral</argument>
            </arguments>
        </referenceBlock>
        <referenceContainer name="content">
            <referenceBlock name="mpreward_referral" remove="true"/>
            <block class="Mageplaza\RewardPointsUltimate\Block\Referral\Index" name="hyva_mpreward_referral" template="Mageplaza_RewardPointsUltimate::referral/hyva-index.phtml" cacheable="false">
                <block class="Mageplaza\RewardPointsUltimate\Block\Referral\Invitee" name="hyva_mpreward_invitee" template="Mageplaza_RewardPointsUltimate::referral/invitee.phtml"/>
            </block>
        </referenceContainer>
    </body>
</page>
