      You Would <span class="font-bold">Love</span> To Know
        </h2>
       <span class="block w-10 h-0.5 bg-red-600 mx-auto mt-8"></span>
    </div>

    <div class="video-grid grid gap-6 sm:grid-cols-1 md:grid-cols-2 scroll-item">
        <?php if (!empty($filteredPosts)): ?>
            <?php foreach ($filteredPosts as $post): ?>
                <div class="video-card bg-white p-0 shadow-sm  transition duration-150 transition">
                    <div class="video-description text-gray-800 mb-1 text-sm md:text-base">
                        <?php echo $post->getShortDescription(); ?>
                    </div>
                    <h3 class="w-full text-black text-lg lg:text-[28px] font-bold p-0 text-left mt-6 mb-4"><?php echo $post->getName(); ?></h3>
                </div>
            <?php endforeach; ?>
        <?php else: ?>
            <p class="text-gray-500">No videos found.</p>
        <?php endif; ?>
    </div>

