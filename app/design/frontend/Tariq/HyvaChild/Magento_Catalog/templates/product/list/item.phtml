<script>
function productcart(productId, initialQty = 0, initialItemId = null, productName = '', productUrl = '/checkout/cart/', hasOptions = false) {
    return {
        qty: initialQty,
        itemId: initialItemId,
        productName,
        productUrl,
        hasOptions,
        loading: false,

        getFormKey() {
            return document.querySelector('input[name="form_key"]')?.value;
        },

        updateMiniCart() {
            fetch('/customer/section/load/?sections=cart')
                .then(res => res.json())
                .then(sections => {
                    window.dispatchEvent(new CustomEvent('private-content-loaded', { detail: sections }));
                    window.dispatchEvent(new CustomEvent('update:drawer-totals'));
                    window.dispatchEvent(new CustomEvent('update:minicart-counter'));
                    window.dispatchEvent(new CustomEvent('reload-customer-section-data'));
                });
        },

        saveMessage(msg) {
            sessionStorage.setItem('cartMessage', msg);
        },

        addToCart() {
            if (this.loading) return;
            this.loading = true;

            fetch("/checkout/cart/add/", {
                method: "POST",
                headers: { 'X-Requested-With': 'XMLHttpRequest' },
                body: new URLSearchParams({
                    product: productId,
                    qty: 1,
                    form_key: this.getFormKey()
                })
            })
            .then(() => {
                clearMagentoMessages();
                this.updateMiniCart();
                this.saveMessage(`You added ${this.productName} to your shopping cart.`);
                location.reload();
            })
            .finally(() => this.loading = false);
        },

        increase() {
            this.itemId ? this.updateQty(this.qty + 1) : this.addToCart();
        },

        decrease() {
            if (!this.itemId) return;
            this.qty > 1 ? this.updateQty(this.qty - 1) : this.removeItem();
        },

        updateQty(newQty) {
            const oldQty = this.qty;
            this.loading = true;

            fetch("/checkout/cart/updatePost/", {
                method: "POST",
                headers: { 'X-Requested-With': 'XMLHttpRequest' },
                body: new URLSearchParams({
                    update_cart_action: "update_qty",
                    [`cart[${this.itemId}][qty]`]: newQty,
                    form_key: this.getFormKey()
                })
            })
            .then(() => {
                const diff = Math.abs(newQty - oldQty);
                const action = newQty > oldQty ? 'added to' : 'removed from';
                this.saveMessage(`${diff} × ${this.productName} ${action} your shopping cart.`);
                location.reload();
            })
            .finally(() => this.loading = false);
        },

        removeItem() {
            if (!this.itemId) return;
            this.loading = true;

            fetch("/checkout/cart/delete/", {
                method: "POST",
                headers: { 'X-Requested-With': 'XMLHttpRequest' },
                body: new URLSearchParams({
                    id: this.itemId,
                    form_key: this.getFormKey()
                })
            })
            .then(() => {
                this.saveMessage(`${this.qty} × ${this.productName} removed from your shopping cart.`);
                location.reload();
            })
            .finally(() => this.loading = false);
        }
    };
}

document.addEventListener('DOMContentLoaded', () => {
    const msg = sessionStorage.getItem('cartMessage');
    if (!msg) return;

    let container = document.getElementById('cart-toast-container');

    if (!container) {
        container = document.createElement('div');
        container.id = 'cart-toast-container';
        document.body.appendChild(container);
    }

    const toast = document.createElement('div');
    toast.className = 'cart-toast success';
    toast.innerHTML = `
        <span>${msg} <a href="/checkout/cart/">View Cart</a></span>
        <button class="toast-close">&times;</button>
    `;

    toast.querySelector('.toast-close').onclick = () => toast.remove();

    container.appendChild(toast);
    toast.classList.add('show');

    sessionStorage.removeItem('cartMessage');
});

function clearMagentoMessages() {
    const messages = document.querySelector('.messages');
    if (messages) messages.innerHTML = '';
}
</script>
