<?php
/** @var \Hyva\Theme\Model\ViewModelRegistry $viewModels */
/** @var \Haartyhanks\RemoveObjectManager\ViewModel\BestsellingCategory $bestselling_category */
/** @var \Haartyhanks\RemoveObjectManager\ViewModel\Custom $current_block */

$bestselling_category = $viewModels->require(\Haartyhanks\RemoveObjectManager\ViewModel\BestsellingCategory::class);
$current_block = $viewModels->require(\Haartyhanks\RemoveObjectManager\ViewModel\Custom::class);

$categoryId = $bestselling_category->getCurrentCategoryId();
$imageHelper = $bestselling_category->getImageHelper();

$bestsell_products = $bestselling_category->getBestSellingProducts(3, $categoryId);
if (!$bestsell_products || count($bestsell_products) === 0) {
    $bestsell_products = $bestselling_category->getBestSellingProducts(3);
}

$currentCategory = $current_block->getCurrentCategory();
$display_mode = $currentCategory->getData('display_mode');
$productCount = $current_block->getEnabledInStockProductCount();
?>
<?php if($productCount >= 8){?>
<?php if ($display_mode === 'PRODUCTS' && $bestsell_products && count($bestsell_products)): ?>
<section class="bestselling-products my-12 lg:my-20 px-0"
    x-data="{
        active: 0,
        total: <?= count($bestsell_products) ?>,
        startX: 0,
        currentX: 0,
        dragging: false,
        next() { this.active = (this.active + 1) % this.total },
        prev() { this.active = (this.active - 1 + this.total) % this.total },
        startDrag(e) {
            this.dragging = true;
            this.startX = e.type.includes('touch') ? e.touches[0].clientX : e.clientX;
        },
        onDrag(e) {
            if(!this.dragging) return;
            this.currentX = e.type.includes('touch') ? e.touches[0].clientX : e.clientX;
        },
        endDrag() {
            if(!this.dragging) return;
            let diff = this.startX - this.currentX;
            if(diff > 50) this.next();
            if(diff < -50) this.prev();
            this.dragging = false;
            this.startX = 0;
            this.currentX = 0;
        },
        goTo(index) { this.active = index }
    }"
>

    <!-- Section Title -->
    <div class="section-title text-center mb-12">
        <h2 class="text-3xl md:text-[38px] font-normal text-black">
            <span class="font-bold">Best Selling</span> in<br class="md:hidden"> Category
        </h2>
        <p class="text-base md:text-[17px] text-black my-4">
            The most popular picks, flying off the shelves – don’t miss out.
        </p>
        <span class="block w-10 h-0.5 bg-red-600 mx-auto mt-6"></span>
    </div>

    <!-- Product List -->
    <div class="best-selling-sec overflow-hidden lg:overflow-visible scroll-item">
        <ul 
            class="flex lg:grid lg:grid-cols-3 gap-6 transition-transform duration-300"
            :style="window.innerWidth < 1024 ? `transform: translateX(-${active * 100}%)` : ''"
            @mousedown="startDrag($event)"
            @mousemove="onDrag($event)"
            @mouseup="endDrag"
            @mouseleave="endDrag"
            @touchstart="startDrag($event)"
            @touchmove="onDrag($event)"
            @touchend="endDrag"
        >
            <?php foreach ($bestsell_products as $_product): ?>
                <?php
                $productUrl   = $_product->getProductUrl();
                $imageUrl     = $imageHelper->init($_product, 'product_small_image')->getUrl();
                $name         = $_product->getName();
                $regularPrice = $_product->getPrice();
                $specialPrice = $_product->getSpecialPrice();

                $specialFromDate = $_product->getSpecialFromDate();
                $specialToDate   = $_product->getSpecialToDate();

                $todayDate   = new \DateTime();
                $specialFrom = $specialFromDate ? new \DateTime($specialFromDate) : null;
                $specialTo   = $specialToDate ? new \DateTime($specialToDate) : null;

                // Special price validity check
                $isSpecialValid = false;
                if (!empty($specialPrice)) {
                    if (
                        (!$specialFrom || $todayDate >= $specialFrom) &&
                        (!$specialTo || $todayDate <= $specialTo)
                    ) {
                        $isSpecialValid = true;
                    }
                }
                ?>

                <li class="min-w-full best-sell-list lg:min-w-0 bg-white shadow hover:shadow-lg transition duration-200 p-0 flex items-start gap-4 w-full lg:w-[380px] hover:-translate-y-2 transition transform duration-300">

                    <div class="best-sell-img w-[120px] h-[120px] flex-shrink-0 shadow">
                        <a href="<?= $productUrl ?>">
                            <img 
                                src="<?= $imageUrl ?>" 
                                alt="<?= $name ?>" 
                                class="w-full h-full object-cover rounded-md"
                            />
                        </a>
                    </div>

                    <div class="flex flex-col text-left">
                        <div class="text-lg lg:text-xl lg:h-18 font-bold text-black lg:!leading-[24px]">
                            <a href="<?= $productUrl ?>"><?= $name ?></a>
                        </div>

                        <div class="flex items-center gap-2 mt-2">
                            <?php if ($isSpecialValid): ?>
                                <div class="text-lg font-bold text-black">
                                    £<?= number_format($specialPrice, 2) ?>
                                    <span class="text-gray-400 line-through ml-2">
                                        £<?= number_format($regularPrice, 2) ?>
                                    </span>
                                </div>
                            <?php else: ?>
                                <div class="text-lg font-bold text-gray-900">
                                    £<?= number_format($regularPrice, 2) ?>
                                </div>
                            <?php endif; ?>
                        </div>
                    </div>

                </li>
            <?php endforeach; ?>
        </ul>
    </div>

    <!-- Mobile Dots -->
    <div class="flex justify-center gap-2 mt-6 lg:hidden">
        <template x-for="i in total" :key="i">
            <span
                class="w-3 h-3 rounded-full cursor-pointer"
                :class="(i-1) === active ? 'bg-red-600' : 'bg-gray-300'"
                @click="goTo(i-1)"
            ></span>
        </template>
    </div>

</section>
<?php endif; ?>
<?php }?>