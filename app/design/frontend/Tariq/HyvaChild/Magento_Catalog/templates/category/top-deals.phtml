function saveCartMessage(message, type = "success") {
    sessionStorage.setItem(
        'cart_message',
        JSON.stringify({ message, type })
    );
}

function showStoredCartMessage(cart) {
    const data = sessionStorage.getItem('cart_message');
    if (!data) return;

    try {
        const { message, type } = JSON.parse(data);
        cart.showPopupMessage(message, type);
    } catch (e) {}

    sessionStorage.removeItem('cart_message');
}

/* ===============================
   MAIN CART FUNCTION
================================ */

function addtobasket(productId, initialQty = 0, initialItemId = null, productName = '', productUrl = '/checkout/cart/', hasOptions = false) {
    const cart = {
        qty: initialQty,
        itemId: initialItemId,
        productName,
        productUrl,
        hasOptions,
        loading: false,

        getFormKey() {
            return document.querySelector('input[name="form_key"]')?.value;
        },

        updateMiniCart() {
            fetch('/customer/section/load/?sections=cart')
                .then(res => res.json())
                .then(sections => {
                    window.dispatchEvent(new CustomEvent('private-content-loaded', { detail: sections }));
                    window.dispatchEvent(new CustomEvent('update:drawer-totals'));
                    window.dispatchEvent(new CustomEvent('update:minicart-counter'));
                    window.dispatchEvent(new CustomEvent('reload-customer-section-data'));
                });
        },

        /* ===============================
           TOAST MESSAGE (NO AUTO HIDE)
        ================================ */
        showPopupMessage(message, type = "success") {
            const container = document.getElementById('cart-toast-container');
            if (!container) return;

            const existingToast = container.querySelector('.cart-toast');
            if (existingToast) existingToast.remove();

            const toast = document.createElement('div');
            toast.className = `cart-toast ${type}`;
            toast.innerHTML = `
                <span>
                    ${message}
                    <a href="/checkout/cart/" style="text-decoration: underline;">View Cart</a>
                </span>
                <button class="toast-close">&times;</button>
            `;

            toast.querySelector('.toast-close').onclick = () => toast.remove();

            container.appendChild(toast);

            // show animation only
            setTimeout(() => toast.classList.add("show"), 50);
        },

        addToCart() {
            if (this.loading) return;
            this.loading = true;

            fetch("/checkout/cart/add/", {
                method: "POST",
                headers: { 'X-Requested-With': 'XMLHttpRequest' },
                body: new URLSearchParams({
                    product: productId,
                    qty: 1,
                    form_key: this.getFormKey()
                })
            })
            .then(() => {
                clearMagentoMessages();
                this.updateMiniCart();

                saveCartMessage(`You added ${this.productName} to your shopping cart.`);
                setTimeout(() => location.reload(), 400);
            })
            .finally(() => this.loading = false);
        },

        increase() {
            this.itemId
                ? this.updateQty(this.qty + 1, true)
                : this.addToCart();
        },

        decrease() {
            if (!this.itemId || this.qty === 0) return;

            this.qty > 1
                ? this.updateQty(this.qty - 1, true)
                : this.removeItem();
        },

        updateQty(newQty, showMsg = false) {
            const oldQty = this.qty;
            this.loading = true;

            fetch("/checkout/cart/updatePost/", {
                method: "POST",
                headers: { 'X-Requested-With': 'XMLHttpRequest' },
                body: new URLSearchParams({
                    update_cart_action: "update_qty",
                    [`cart[${this.itemId}][qty]`]: newQty,
                    form_key: this.getFormKey()
                })
            })
            .then(() => {
                this.qty = newQty;
                this.updateMiniCart();

                if (showMsg) {
                    const diff = Math.abs(newQty - oldQty);
                    const action = newQty > oldQty ? 'added to' : 'removed from';
                    saveCartMessage(`${diff} × ${this.productName} ${action} your shopping cart.`);
                }

                setTimeout(() => location.reload(), 400);
            })
            .finally(() => this.loading = false);
        },

        removeItem() {
            if (!this.itemId) return;
            this.loading = true;

            fetch("/checkout/cart/delete/", {
                method: "POST",
                headers: { 'X-Requested-With': 'XMLHttpRequest' },
                body: new URLSearchParams({
                    id: this.itemId,
                    form_key: this.getFormKey()
                })
            })
            .then(() => {
                saveCartMessage(`${this.qty} × ${this.productName} removed from your shopping cart.`);
                this.qty = 0;
                this.itemId = null;
                this.updateMiniCart();
                setTimeout(() => location.reload(), 400);
            })
            .finally(() => this.loading = false);
        }
    };
    window.cartInstance = cart;
    return cart;
}

/* ===============================
   PAGE LOAD HANDLER
================================ */

document.addEventListener('DOMContentLoaded', () => {
    if (window.cartInstance) {
        showStoredCartMessage(window.cartInstance);
    }

    const msgWrapper = document.querySelector('.page.messages, .messages');
    if (msgWrapper) msgWrapper.innerHTML = '';
});


function clearMagentoMessages() {
    const messagesContainer = document.querySelector('.messages');
    if (messagesContainer) {
        messagesContainer.innerHTML = '';
    }
}

window.dealsProducts = function () {
  return {
        currentIndex: 0,
        products: Alpine.store("dealsProducts"),
        slidesPerView: 4,
        isDragging: false,
        dragged: false,
        startX: 0,
        currentTranslate: 0,
        prevTranslate: 0,

        init() {
            this.updateSlidesPerView();
            window.addEventListener("resize", () => this.updateSlidesPerView());
            this.currentTranslate = -this.currentIndex * 100;
        },

        updateSlidesPerView() {
            const width = window.innerWidth;
            if (width >= 1024) this.slidesPerView = 4;
            else if (width >= 768) this.slidesPerView = 2;
            else this.slidesPerView = 2;
        },

        get totalDots() {
        if (!this.products?.length) return 1;
       return Math.ceil(this.products.length / this.slidesPerView);
       },

        maxIndex() {
            return this.totalDots - 1;
        },

        goToSlide(i) {
            this.currentIndex = Math.max(0, Math.min(i, this.maxIndex()));
            this.currentTranslate = -this.currentIndex * 100;
        },

        prev() { this.goToSlide(this.currentIndex - 1); },
        next() { this.goToSlide(this.currentIndex + 1); },
        dragStart(e) {
      if (e.type.includes("mouse")) e.preventDefault();
      this.isDragging = true;
      this.dragged = false;
      this.startX = e.type.includes("mouse") ? e.pageX : e.touches[0].clientX;
      this.prevTranslate = -this.currentIndex * 100;
    },

        dragMove(e) {
            if (!this.isDragging) return;
            const currentX = e.type.includes("mouse") ? e.pageX : e.touches[0].clientX;
            const diff = currentX - this.startX;

            if (Math.abs(diff) > 5) this.dragged = true;
            this.currentTranslate = this.prevTranslate + (diff / window.innerWidth) * 100;
        },

        dragEnd() {
            if (!this.isDragging) return;
            this.isDragging = false;
            const moved = this.currentTranslate - this.prevTranslate;

            if (moved < -10) this.next();
            else if (moved > 10) this.prev();
            else this.goToSlide(this.currentIndex);
        },
       get sliderStyle() {
    if (this.products.length < 4) {
        return "transform: translateX(0);"; // no sliding
    }

    return `
        transform: translateX(${this.currentTranslate}%);
        transition: ${this.isDragging ? 'none' : 'transform .5s ease'};
    `;
}

    }
};

