<div class="best_seller">
    <div class="section-title">
    <h2><strong>Best</strong> Selling</h2>
    <p>Our most-loved halal meats – handpicked by thousands of happy customers.</p>
    <span class="underline"></span>
  </div>
 <?php $bestselling = $block->getLayout()->createBlock(\Haartyhanks\RemoveObjectManager\Block\BestSellers::class);
 $wishlistHelper = $this->helper("Magento\Wishlist\Helper\Data");
 $customerSession = $block->getLayout()->createBlock(\Haartyhanks\RemoveObjectManager\Block\RemoveObj::class);
 $isLoggedIn = $customerSession->getCustomerData()->isLoggedIn();
 $bestsell_products = $bestselling->getBestSellingProducts(15) ?? [];
 $formKey = $bestselling->getFormKey();

 //if (count($bestsell_products)): ?>

<div class="best-sellers">
   <?php foreach ($bestsell_products as $product):
       $image = $bestselling->getProductImage($product);
       $specialPrice = $product->getSpecialPrice();
       $regularPrice = $product->getPrice();
        $specialFromDate    = $product->getSpecialFromDate();
        $specialToDate      = $product->getSpecialToDate();
        $currentDate        = date('Y-m-d');
       $inWishlist = false;

       if ($isLoggedIn) {
           $wishlist = $wishlistHelper->getWishlist();
           if ($wishlist) {
               $wishlistItems = $wishlist->getItemCollection();
               foreach ($wishlistItems as $item) {
                   if ($item->getProductId() == $product->getId()) {
                       $inWishlist = true;
                       break;
                   }
               }
           }
       }
       ?>

    <div class="bestsell-item">
        <div class="product-item-photo" style="position: relative;">
           <?php if ($specialPrice && ($specialFromDate <= $currentDate) && $specialPrice < $regularPrice) {
               $discount = round(100 - ($specialPrice / $regularPrice) * 100);
               echo '<div class="discount-badge">' .
                   $discount .
                   "%<br>OFF</div>";
           } ?>
           <?php $createdAt = $product->getCreatedAt();
$isNew = false;

if ($createdAt) {
    $createdDate = new \DateTime($createdAt);
    $now = new \DateTime();
    $interval = $now->diff($createdDate)->days;

    if ($interval <= 5) {
        $isNew = true;
    }
}
?>

<?php if ($isNew): ?>
    <div class="custom-new-label">
        <span>NEW</span>
    </div>
<?php endif; ?>
        <a href="<?= $product->getProductUrl() ?>">
           <?= $image->toHtml() ?>
        </a>
        <?php if ($isLoggedIn):?>
    <?php if (!$inWishlist): ?>
        <!-- Not in wishlist, show blank heart -->
        <form action="<?= $block->getUrl(
            "wishlist/index/add"
        ) ?>" method="post" class="custom-wishlist-form">
            <input type="hidden" name="product" value="<?= $product->getId() ?>" />
            <input type="hidden" name="form_key" value="<?= $formKey ?>" />
            <button type="submit" class="wishlist-btn" title="Add to Wishlist">
                <img src="<?php echo $block->getViewFileUrl(
                    "images/heart.svg"
                ); ?>" alt="heart" />
            </button>
        </form>
    <?php else: ?>
        <!-- Already in wishlist, show red heart -->
        <span class="wishlist-btn added" title="Already in Wishlist">
            <img src="<?php echo $block->getViewFileUrl(
                "images/heart-red.svg"
            ); ?>" alt="heart-red" />
        </span>
    <?php endif; ?>
<?php else: ?>
    <!-- Not logged in -->
    <a href="<?= $block->getUrl(
        "customer/account/login"
    ) ?>" class="wishlist-btn" title="Login to add to Wishlist">
        <img src="<?php echo $block->getViewFileUrl(
            "images/heart.svg"
        ); ?>" alt="heart" />
    </a>
<?php endif; ?>
        </div>
            <div class="bestsell-product-name">
               <a href="<?= $product->getProductUrl() ?>">
              <?= $block->escapeHtml($product->getName()) ?>
        </a>
    </div>
     <?php if ($product->getSpecialPrice() != "" && ($specialFromDate <= $currentDate)) { ?>            
              <div class="bestsell-product-price">£<?= __(
                  number_format($specialPrice, 2)
              ) ?>
              <span style="text-decoration: line-through;">£<?= __(
                  number_format($regularPrice, 2)
              ) ?>  
              </span>
           </div>
            <?php } else { ?>
              <div class="bestsell-product-price">£<?= __(
                  number_format($regularPrice, 2)
              ) ?></div>
              
            <?php } ?>
            <?php if ($product->getWeight() != "") { ?>
            <div class="bestsell-product-weight">
               <?php
               $value = $product->getWeight();
               echo "Weight " .
                   rtrim(
                       rtrim(
                           number_format($value, 4, ".", ""),

                           "0"
                       ),
                       "."
                   );
               ?>

              </div>
           <?php } ?>
              <span class="vip-points">Get 2 VIP Points</span>
              <?php $productId = $product->getId();
              $baseUrl = $block->getBaseUrl();
              $hasAnyOptions = $product->getHasOptions();
              $productUrl = $block->escapeUrl($product->getProductUrl());
           if ($hasAnyOptions): ?>
        <button type="button"
