     } ?>
                    <?php
                    $createdAt = $_product->getCreatedAt();
                    $isNew = false;
                    if ($createdAt) {
                        $createdDate = new \DateTime($createdAt);
                        $now = new \DateTime();
                        $interval = $now->diff($createdDate)->days;
                        if ($interval <= 7) {
                            $isNew = true;
                        }
                    }
                    ?>
<?php if ($isNew): ?>
    <div class="custom-new-label">
        <span>NEW</span>
    </div>
<?php endif; ?>
