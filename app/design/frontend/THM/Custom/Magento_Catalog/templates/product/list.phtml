        <button class="btn-increase">+</button>
    </div>
</div>
<?php endif; ?>
                            <?php if ($showDescription): ?>
                                <div class="product description product-item-description">
                                    <?= $_helper->productAttribute(
                                        $_product,
                                        $_product->getShortDescription(),
                                        "short_description"
