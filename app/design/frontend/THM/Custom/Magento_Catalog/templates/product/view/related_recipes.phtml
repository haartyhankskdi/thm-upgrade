<?php 
// Get Mageplaza blog post block
$block = $block->getLayout()->createBlock(\Mageplaza\Blog\Block\Listpost::class);
$currentCategoryBlock = $block->getLayout()->createBlock(\Haartyhanks\RemoveObjectManager\Block\RemoveObj::class);
$currentProduct   = $currentCategoryBlock->getCurrentProductId();
$currentCategory  = $currentCategoryBlock->getCurrentCategory();
$recipe_catid     = $currentCategory ? $currentCategory->getData('recipe_cat_id') : null;
$productCategoryIds = $currentProduct ? $currentProduct->getCategoryIds() : [];

$postCollection = $block->getPostCollection(); 
$baseUrl = $block->getBaseUrl();

$postCollection->addFieldToFilter('enabled', 1);
$postCollection->setOrder('publish_date', 'DESC');
$postCollection->setCurPage(1);

$filteredPosts = [];
if (!empty($productCategoryIds)) {
    foreach ($postCollection as $post) {
        $postModel = $post->load($post->getId());
        $categoryIds = $postModel->getCategoryIds();

        if (!empty(array_intersect($productCategoryIds, $categoryIds)) && $postModel->getShortDescription()) {
            $filteredPosts[] = $postModel;
        }
        if (count($filteredPosts) >= 2) break;
    }
}

if (empty($filteredPosts) && !empty($recipe_catid)) {
    foreach ($postCollection as $post) {
        $postModel = $post->load($post->getId());
        $categoryIds = $postModel->getCategoryIds();

        if (in_array($recipe_catid, $categoryIds) && $postModel->getShortDescription()) {
            $filteredPosts[] = $postModel;
        }
        if (count($filteredPosts) >= 2) break;
    }
}

if (empty($filteredPosts)) {
    foreach ($postCollection as $post) {
        if ($post->getShortDescription()) {
            $filteredPosts[] = $post;
        }
        if (count($filteredPosts) >= 2) break;
    }
}
?>

<div class="video-section">
    <h1 class="main-title">Watch. Learn. Cook with Confidence.</h1>
    <p class="subtitle">
        From mouth-watering halal recipes to expert butchery tips - discover the secrets behind every cut.
    </p>

    <div class="video-grid">
        <?php if (count($filteredPosts)): ?>
            <?php foreach ($filteredPosts as $post): ?>
                <div class="video-card">
                    <?php echo $post->getShortDescription(); ?>
                    <span><?php echo $post->getName(); ?></span>
                </div>
            <?php endforeach; ?>
        <?php else: ?>
            <p>No videos found.</p>
        <?php endif; ?>
    </div>

    <div class="cta-button">
        <a href="<?php echo $baseUrl ?>recipes" class="view-all">VIEW ALL RECIPES</a>
    </div>
</div>


