<!--review main click show review section  -->
<script type="text/javascript">
require(['jquery'], function ($) {
    $('.reviews-actions a').on('click', function (e) {
        e.preventDefault();
        document.querySelector('.adel-review-section')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
});
</script>