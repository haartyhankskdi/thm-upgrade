<?php
/** @var \Haartyhanks\AutoUpsell\Block\Product\View\AccordionAttributes $block */

$accordionAttributes = [
    'description' => 'Description',
    'ingredients' => 'Ingredients',
    'storage_guidelines' => 'Storage Guidelines',
    'cooking_suggestions' => 'Cooking Suggestions'
];

$accordionItems = [];

foreach ($accordionAttributes as $code => $label) {
    $value = $block->getProductAttributeValue($code);
    if ($value) {
        $accordionItems[] = [
            'id' => $code . '-tab',
            'title' => $label,
            'content' => $value
        ];
    }
}
?>

<?php if (!empty($accordionItems)): ?>
    <div class="product info detailed accordion-container">
        <?php foreach ($accordionItems as $item): ?>
            <div class="accordion-item">
                <div class="accordion-header" data-target="#<?= $block->escapeHtmlAttr($item['id']) ?>">
                    <h3>
                        <?= $block->escapeHtml($item['title']) ?>
                        <span class="accordion-icon"></span>
                    </h3>
                </div>
                <div class="accordion-content"
                     id="<?= $block->escapeHtmlAttr($item['id']) ?>"
                     style="display:none;">
                    <?= /* @noEscape */ $item['content'] ?>
                </div>
            </div>
        <?php endforeach; ?>
    </div>
<?php endif; ?>

<style>
    .accordion-header {
        cursor: pointer;
        border-bottom: 1px solid #ddd;
        padding: 12px 15px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .accordion-header h3 {
        margin: 0;
        font-size: 16px;
        font-weight: 500;
        flex-grow: 1;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .accordion-icon::after {
        content: "\276F"; /* › */
        font-size: 16px;
        transition: transform 0.3s ease;
    }

    .accordion-header.active .accordion-icon::after {
        transform: rotate(90deg); /* › se ˅ */
    }
</style>