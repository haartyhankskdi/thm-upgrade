    z-index: 10;
    background: #fff;
    border-radius: 50%;
    width: 36px;
    height: 36px;
    box-shadow: 0 0 5px rgba(0,0,0,0.2);
}
.upsell-content .slick-prev:before,
.upsell-content .slick-next:before {
    color: #333;
    font-size: 18px;
}
