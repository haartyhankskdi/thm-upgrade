<?php
/** @var \Haartyhanks\AutoUpsell\Block\ProductInfo $block */
/** @var \Magento\Catalog\Model\Product $_product */

// Get product from registry
$_product = $block->getProduct();
?>

<?php if ($_product && $block->isInStock($_product)): ?>
    <div class="product-stock-status instock">In stock | Usually dispatched within 24 hours</div>
<?php elseif ($_product): ?>
    <div class="product-stock-status outofstock">Out of stock</div>
<?php endif; ?>

<!-- Payment Logo Section -->
<img src="<?= $block->getViewFileUrl('images/payment_detail.png') ?>" 
     alt="Trust Badge" 
     class="after-wishlist-image" 
     />
     
