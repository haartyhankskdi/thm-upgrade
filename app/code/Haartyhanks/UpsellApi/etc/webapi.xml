<?xml version="1.0"?>
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Webapi:etc/webapi.xsd">

    <route url="/V1/related-products/sku/:sku" method="GET">
        <service class="Haartyhanks\UpsellApi\Api\RelatedProductsBySkuInterface"
                 method="getRelatedProducts"/>
        <resources>
            <resource ref="anonymous"/>
        </resources>
    </route>
    <route url="/V1/related-recipes/:productId" method="GET">
    <service class="Haartyhanks\UpsellApi\Api\RelatedRecipesInterface" method="getRelatedRecipes"/>
    <resources>
        <resource ref="anonymous"/>
    </resources>
</route>

</routes>
