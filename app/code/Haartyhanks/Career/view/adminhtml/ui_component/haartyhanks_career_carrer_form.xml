<?xml version="1.0" ?>
<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
	<argument name="data" xsi:type="array">
		<item name="js_config" xsi:type="array">
			<item name="provider" xsi:type="string">haartyhanks_career_carrer_form.carrer_form_data_source</item>
		</item>
		<item name="label" xsi:type="string" translate="true">General Information</item>
		<item name="template" xsi:type="string">templates/form/collapsible</item>
	</argument>
	<settings>
		<buttons>
			<button name="back" class="Haartyhanks\Career\Block\Adminhtml\Carrer\Edit\BackButton"/>
			<button name="delete" class="Haartyhanks\Career\Block\Adminhtml\Carrer\Edit\DeleteButton"/>
			<button name="save" class="Haartyhanks\Career\Block\Adminhtml\Carrer\Edit\SaveButton"/>
			<button name="save_and_continue" class="Haartyhanks\Career\Block\Adminhtml\Carrer\Edit\SaveAndContinueButton"/>
		</buttons>
		<namespace>haartyhanks_career_carrer_form</namespace>
		<dataScope>data</dataScope>
		<deps>
			<dep>haartyhanks_career_carrer_form.carrer_form_data_source</dep>
		</deps>
	</settings>
	<dataSource name="carrer_form_data_source">
		<argument name="data" xsi:type="array">
			<item name="js_config" xsi:type="array">
				<item name="component" xsi:type="string">Magento_Ui/js/form/provider</item>
			</item>
		</argument>
		<settings>
			<submitUrl path="*/*/save"/>
		</settings>
		<dataProvider name="carrer_form_data_source" class="Haartyhanks\Career\Model\Carrer\DataProvider">
			<settings>
				<requestFieldName>carrer_id</requestFieldName>
				<primaryFieldName>carrer_id</primaryFieldName>
			</settings>
		</dataProvider>
	</dataSource>
	<fieldset name="general">
		<settings>
			<label>General</label>
		</settings>
		<field name="first_name" formElement="input" sortOrder="10">
			<argument name="data" xsi:type="array">
				<item name="config" xsi:type="array">
					<item name="source" xsi:type="string">Carrer</item>
				</item>
			</argument>
			<settings>
				<dataType>text</dataType>
				<label translate="true">first_name</label>
				<dataScope>first_name</dataScope>
				<validation>
					<rule name="required-entry" xsi:type="boolean">false</rule>
				</validation>
			</settings>
		</field>
		<field name="last_name" formElement="input" sortOrder="20">
			<argument name="data" xsi:type="array">
				<item name="config" xsi:type="array">
					<item name="source" xsi:type="string">Carrer</item>
				</item>
			</argument>
			<settings>
				<dataType>text</dataType>
				<label translate="true">last_name</label>
				<dataScope>last_name</dataScope>
				<validation>
					<rule name="required-entry" xsi:type="boolean">false</rule>
				</validation>
			</settings>
		</field>
		<field name="phone" formElement="input" sortOrder="30">
			<argument name="data" xsi:type="array">
				<item name="config" xsi:type="array">
					<item name="source" xsi:type="string">Carrer</item>
				</item>
			</argument>
			<settings>
				<dataType>text</dataType>
				<label translate="true">phone</label>
				<dataScope>phone</dataScope>
				<validation>
					<rule name="required-entry" xsi:type="boolean">false</rule>
				</validation>
			</settings>
		</field>
		<field name="email" formElement="textarea" sortOrder="40">
			<argument name="data" xsi:type="array">
				<item name="config" xsi:type="array">
					<item name="source" xsi:type="string">Carrer</item>
				</item>
			</argument>
			<settings>
				<dataType>text</dataType>
				<label translate="true">email</label>
				<dataScope>email</dataScope>
				<validation>
					<rule name="required-entry" xsi:type="boolean">false</rule>
				</validation>
			</settings>
		</field>
		<field name="role" formElement="input" sortOrder="50">
			<argument name="data" xsi:type="array">
				<item name="config" xsi:type="array">
					<item name="source" xsi:type="string">Carrer</item>
				</item>
			</argument>
			<settings>
				<dataType>text</dataType>
				<label translate="true">role</label>
				<dataScope>role</dataScope>
				<validation>
					<rule name="required-entry" xsi:type="boolean">false</rule>
				</validation>
			</settings>
		</field>
		<field name="location" formElement="input" sortOrder="60">
			<argument name="data" xsi:type="array">
				<item name="config" xsi:type="array">
					<item name="source" xsi:type="string">Carrer</item>
				</item>
			</argument>
			<settings>
				<dataType>text</dataType>
				<label translate="true">location</label>
				<dataScope>location</dataScope>
				<validation>
					<rule name="required-entry" xsi:type="boolean">false</rule>
				</validation>
			</settings>
		</field>
		<field name="attachment" formElement="textarea" sortOrder="70">
			<argument name="data" xsi:type="array">
				<item name="config" xsi:type="array">
					<item name="source" xsi:type="string">Carrer</item>
				</item>
			</argument>
			<settings>
				<dataType>text</dataType>
				<label translate="true">attachment</label>
				<dataScope>attachment</dataScope>
				<validation>
					<rule name="required-entry" xsi:type="boolean">false</rule>
				</validation>
			</settings>
		</field>
		<field name="created_at" formElement="date" sortOrder="80">
			<argument name="data" xsi:type="array">
				<item name="config" xsi:type="array">
					<item name="source" xsi:type="string">Carrer</item>
				</item>
			</argument>
			<settings>
				<dataType>text</dataType>
				<label translate="true">created_at</label>
				<dataScope>created_at</dataScope>
				<validation>
					<rule name="required-entry" xsi:type="boolean">false</rule>
				</validation>
			</settings>
		</field>
		<field name="updated_at" formElement="date" sortOrder="90">
			<argument name="data" xsi:type="array">
				<item name="config" xsi:type="array">
					<item name="source" xsi:type="string">Carrer</item>
				</item>
			</argument>
			<settings>
				<dataType>text</dataType>
				<label translate="true">updated_at</label>
				<dataScope>updated_at</dataScope>
				<validation>
					<rule name="required-entry" xsi:type="boolean">false</rule>
				</validation>
			</settings>
		</field>
	</fieldset>
</form>
