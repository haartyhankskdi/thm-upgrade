        </svg>
        <img src="<?= $block->getViewFileUrl('images/delivery-van-i.svg'); ?>" alt="delivery-van-i" class="absolute w-6 h-6 top-[9px]">
    </div>
</div>

</div>

<script>
function cartProgress(total) {
    const milestones = [
        { min: 0, max: 45, label: '5% Discount' },
        { min: 45, max: 75, label: '10% Discount' },
        { min: 75, max: 100, label: 'Free Delivery' }
    ];

    function calculateProgress(total) {
        for (let i = 0; i < milestones.length; i++) {
            const m = milestones[i];
            if (total <= m.max) {
                const rangeStart = i === 0 ? 0 : milestones[i - 1].max;
                const rangeEnd = m.max;
                const rangeWidth = rangeEnd - rangeStart;

                const milestoneStartPercent = i === 0 ? 0 : (i / milestones.length) * 100;
                const milestoneEndPercent = ((i + 1) / milestones.length) * 100;

                const progress = milestoneStartPercent + ((total - rangeStart) / rangeWidth) * (milestoneEndPercent - milestoneStartPercent);
                return Math.min(progress, 100);
            }
        }
        return 100;
    }

    return {
        total: total,
        progress: calculateProgress(total),
        remaining: Math.max(100 - total, 0),

        nextReward() {
            if (total < 45) return '5% Discount';
            if (total < 75) return '10% Discount';
            if (total < 100) return 'Free Delivery';
            return '';
        },

        currentMilestone(min, max) {
            return total > min && total <= max;
        }
    }
}
</script>
