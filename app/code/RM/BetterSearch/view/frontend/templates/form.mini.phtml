<!-- Alpine Logic -->
<script>
document.addEventListener('alpine:init', () => {
  Alpine.data('betterSearch', () => ({

    query: '',
    products: [],
    filtered: [],
    showDropdown: false,
    mediaUrl: '<?= $mediaUrl ?>',
    placeholder: '<?= $getPlaceholderImage ?>',

    // Slider + Pagination
    currentPage: 1,
    slidesToShow: 3,

    // Total pages
    get totalPages() {
      return Math.ceil(this.filtered.length / this.slidesToShow) || 1;
    },

    get visibleSlides() {
      let start = (this.currentPage - 1) * this.slidesToShow;
      return this.filtered.slice(start, start + this.slidesToShow);
    },

    onInput() {
      if (this.query.trim().length < 2) {
        this.showDropdown = false;
        this.filtered = [];
        return;
      }
      if (!this.products.length) {
        this.waitProducts().then(() => this.search());
      } else {
        this.search();
      }
    },

    waitProducts() {
      return new Promise((resolve) => {
        let t = setInterval(() => {
          if (window.bs_product_search?.length) {
            this.products = window.bs_product_search;
            clearInterval(t);
            resolve();
          }
        }, 100);
      });
    },

    // Search Filter
    search() {
      const q = this.query.toLowerCase();
      this.filtered = this.products
        .filter(p => p.pn.toLowerCase().includes(q))
        .map(p => ({
          ...p,
          imgUrl: p.img && !p.img.includes('no_selection')
                    ? this.mediaUrl + p.img
                    : this.mediaUrl + 'catalog/product/placeholder/' + this.placeholder
        }));

      this.currentPage = 1;
      this.showDropdown = true;
    },

    // Pagination Actions
    goToPage(page) {
      if (page >= 1 && page <= this.totalPages) this.currentPage = page;
    },
    nextPage() {
      if (this.currentPage < this.totalPages) this.currentPage++;
    },
    prevPage() {
      if (this.currentPage > 1) this.currentPage--;
    },

    hideOutside(e) {
      if (!e.target.closest('#search_mini_form')) this.showDropdown = false;
    }

  }));
});
</script>
