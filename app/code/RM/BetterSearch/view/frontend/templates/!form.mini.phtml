    $mediaUrl = $betterSearchHelper->mediaUrl();
    $foldername = $betterSearchHelper->foldername();
    $storeCode = $betterSearchHelper->storeCode();
    $getPlaceholderImage = $betterSearchHelper->getPlaceholderImage();
    // echo $this->getRequest()->getFullActionName();
