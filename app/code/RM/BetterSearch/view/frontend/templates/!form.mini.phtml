    //you are on the homepage
?>

<script async src="<?php echo $mediaUrl.$foldername.'/'.$storeCode.'.js'; ?>"></script>

<script>
    requirejs(['jquery'], function($) {

        $(".autocomplete-suggestions").hide();

        // Actions
        /* serchField.focus(function (e) {
            e.preventDefault();
            $(this).val('');
            productSection.html('');
            footerProductSection.find('.paginationDiv').html('');
            // autocomplete_suggestions.show().addClass('active');
        }); */

        /* serchField.blur(function (e) {
            e.preventDefault();
            // autocomplete_suggestions.hide().removeClass('active');
            // productSection.html('');
            footerProductSection.find('.paginationDiv').html('');
        }); */

        $(".autocomplete-suggestions").on("click", ".pagination", function (e) {
            e.preventDefault();
            let self = $(this);
            $(".pagination").removeClass('active');
            self.addClass('active');
            var getActive = self.data('pageactive');
            $(".search-productListItem").removeClass('active');
            $("."+getActive).addClass('active');
        });

        $("#search").keyup(function (e) {
            e.preventDefault();
            serchMe();
        });

        $("#catalog_serch").change(function (e) {
            e.preventDefault();
            serchMe();
        });

        function serchMe() {

            // Property
            var autocomplete_suggestions = $(".autocomplete-suggestions");
            var serchField = $("#search");
            var productSection = $("#productSection");
            var footerProductSection = $("#footerProductSection");
            var resourceSection = $("#resourceSection");
            var mediaUrl = "<?php echo $mediaUrl; ?>";
            // serch property
            var query = serchField.val();
            var productCount = 0;
            var pagination = 0;
            var paginationButton = 0;
            var activeClass = '';
            var category_id = $("#catalog_serch").val();

            // Reset
            productSection.html('');
            footerProductSection.find('.paginationDiv').html('');
            // alert(query);
            // alert(bs_product_search);
            if(query.length > 1){

            $.map(bs_product_search, function (element, index) {

                // prepare a regex object for search
                // let searchMe = new RegExp(query.toLowerCase(), 'i');

                var placeholderImg = mediaUrl+'catalog/product/placeholder/<?php echo $getPlaceholderImage; ?>';
                /* element.pn.toLowerCase().startsWith(query.toLowerCase()) */
                    let catAssume = element.cname.filter(item => {
                                        if(item.toLowerCase().startsWith(query.toLowerCase())) return item;
                                        let newItem = item.split(" ");
                                        for (let index = 0; index < newItem.length; index++) {
                                            if((newItem[index]).toLowerCase().startsWith(query.toLowerCase())){
                                                return (newItem[index]).toLowerCase();
                                            }
                                        }
                                    });

                // if(element.pn.toLowerCase().includes(query.toLowerCase()) || element.cname.filter(item => searchMe.test(item)) != ''){
                if(element.pn.toLowerCase().includes(query.toLowerCase()) || catAssume.length > 0){

                    // console.log(catAssume);

                    // catwise Filter
                    var catArr = element.cids;
                    var catFlag = false;

                    if(category_id != '' && catArr.includes(category_id)){
                        catFlag = true;
                    }else if(category_id == ''){
                        catFlag = true;
                    }


                    if( catFlag == true ){

                        // pagination
                        productCount = productCount + 1;
                        pagination = Math.ceil(productCount / 3);

                        // Check if Image is empty or not
                        if(element.img.length !== 0){
                            if(!element.img.includes("productno_selection")){
                                // set Image url
                                placeholderImg = mediaUrl+element.img;
                            }
                            // console.log(placeholderImg);
                        }
                        // Product Section come here

                        if(pagination === 1){
                            activeClass = 'active';
                        }else{
                            activeClass = '';
                        }

                        if(pagination < 6){
                            productSection.append(`
                                <div class="search-productListItem ${activeClass} active-${pagination}">
                                    <a class="search-productItem-link" href="${element.pu}">
                                    <img class="Search-productItemImage" src="${placeholderImg}" alt="${element.pn}">
                                        <div class="Search-productItemContent">
                                            <p class="Search-productItemTitle">${element.pn}</p>
                                            <div class="Search-productItemActions">
                                                <div class="Search-productItemBtn-shop">
                                                    <a href="${element.pu}" class="button button--primary-light button--size-small ">
                                                        <span class="button__content">View More</span>
                                                    </a>
                                                </div>
                                            </div>
                                        </div>
                                    </a>
                                </div>
                            `);

                            if(pagination !== paginationButton){
                                let pagiActive = (pagination == 1)?"active":"";
                                footerProductSection.find('.paginationDiv').append(`
                                    <button type="button" class="pagination ${pagiActive}" data-pageactive="active-${pagination}">${pagination}</button>
                                `);
                            }
                            // console.log(paginationButton+' = '+pagination);

                            paginationButton = pagination;

                        }
                    }
                }
            });

            // Footer section serch count
            footerProductSection.find('.resultCount').find('.count').html(productCount);

            // Resource come here

            // Activing tab
            autocomplete_suggestions.show().addClass('active');

            }else{
                // Sachin bol kya dalu yaha PlaceHolder Image Or OOp wala message
                // please input more then one letter
                productSection.html('');
                autocomplete_suggestions.hide().removeClass('active');
            }

         }

         $('body').on('click', function(e) {
            var searchBox = $('#search_mini_form');
            if(!searchBox.is(e.target) &&  searchBox.has(e.target).length === 0) {
                $(".autocomplete-suggestions").hide();
            }
        });

    });
</script>

