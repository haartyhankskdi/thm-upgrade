<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="sales_order_payment">
        <column xsi:type="varchar" name="last_trans_id" nullable="true" length="100" comment="Last Trans Id"/>
        <column xsi:type="decimal" name="total_released" scale="4" precision="20" unsigned="false" nullable="true"
                comment="Total Amount Released"/>
    </table>
    <table name="sagepaysuite_token">
        <column xsi:type="int" name="id" nullable="false" identity="true" comment="Token Id"/>
        <column xsi:type="int" name="customer_id" unsigned="true" nullable="false" comment="Customer Id"/>
        <column xsi:type="varchar" name="token" length="150" nullable="false" comment="Token"/>
        <column xsi:type="varchar" name="cc_last_4" length="100" comment="Cc Last 4"/>
        <column xsi:type="varchar" name="cc_exp_month" length="12" comment="Cc Exp Month"/>
        <column xsi:type="varchar" name="cc_type" length="32" comment="Cc Type"/>
        <column xsi:type="varchar" name="cc_exp_year" length="4" comment="Cc Exp Year"/>
        <column xsi:type="varchar" name="vendorname" length="100" comment="Vendorname"/>
        <column xsi:type="timestamp" name="created_at" nullable="false" default="CURRENT_TIMESTAMP" comment="Created At"/>
        <column xsi:type="smallint" name="store_id" unsigned="true" comment="Store Id"/>
        <column xsi:type="varchar" name="payment_method" length="100" nullable="false" default="sagepaysuiteserver" comment="Payment method"/>
        <column xsi:type="smallint" name="vault_id" default="0" nullable="true"  comment="Magento Vault id"/>
        <column xsi:type="smallint" name="migrated" default="0" nullable="true"  comment="Migrate mark"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="id"/>
        </constraint>
        <index referenceId="customer_id" indexType="btree">
            <column name="customer_id"/>
        </index>
    </table>

    <table name="sagepaysuite_sca_params">
        <column xsi:type="int" name="id" nullable="false" identity="true" comment="Table Id"/>
        <column xsi:type="int" name="quote_id" nullable="false" comment="Quote Id"/>
        <column xsi:type="boolean" name="js_enabled" nullable="false" comment="Browser JS enabled"/>
        <column xsi:type="boolean" name="java_enabled" nullable="false" comment="Browser Java enabled"/>
        <column xsi:type="int" name="color_depth" nullable="false" comment="Browser color depth"/>
        <column xsi:type="int" name="screen_height" nullable="false" comment="Browser screen height"/>
        <column xsi:type="int" name="screen_width" nullable="false" comment="Browser screen width"/>
        <column xsi:type="int" name="time_zone" nullable="false" comment="Browser time zone"/>
        <column xsi:type="text" name="accept_header" nullable="false" comment="Browser accept header"/>
        <column xsi:type="text" name="language" nullable="false" comment="Browser language"/>
        <column xsi:type="text" name="user_agent" nullable="false" comment="Browser user agent"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="id"/>
        </constraint>
    </table>
    <table name="sales_payment_transaction">
        <column xsi:type="boolean" name="sagepaysuite_fraud_check" nullable="false" default="0" comment="Opayo Fraud Check Flag"/>
    </table>
    <table name="sagepaysuite_synced_orders">
        <column xsi:type="int" name="id" nullable="false" identity="true" comment="Table Id"/>
        <column xsi:type="int" name="order_id" unsigned="true" nullable="false" comment="Order Id"/>
        <column xsi:type="text" name="status_code" nullable="false" comment="Transaction status code"/>
        <column xsi:type="text" name="status_detail" nullable="false" comment="Transaction status detail"/>
        <column xsi:type="int"  name="sync_attempts" unsigned="true" nullable="false" comment="Sync attempts number"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="id"/>
        </constraint>
        <index referenceId="id" indexType="btree">
            <column name="id"/>
        </index>
        <index referenceId="order_id" indexType="btree">
            <column name="order_id"/>
        </index>
    </table>
    <table name="vault_payment_token">
        <column xsi:type="varchar" name="sagepaysuite_vendorname" length="100" comment="Vendorname"/>
        <index referenceId="sagepaysuite_vendorname" indexType="btree">
            <column name="sagepaysuite_vendorname"/>
        </index>
    </table>
    <table name="sagepay_acsurl_domains" resource="default" engine="innodb" comment="SagePay ACS URL Domains">
        <column xsi:type="int" name="id" padding="10" unsigned="true" nullable="false" identity="true" comment="ID"/>
        <column xsi:type="varchar" name="domain" nullable="false" length="255" comment="ACS URL Domain"/>
        <column xsi:type="timestamp" name="created_at" nullable="false" default="CURRENT_TIMESTAMP" on_update="false" comment="Created At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="id"/>
        </constraint>
    </table>
</schema>
