<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Cron:etc/crontab.xsd">
    <group id="default">
        <job name="ebizmarts_sagepaysuite_cancel_orders" instance="Ebizmarts\SagePaySuite\Model\Cron" method="cancelPendingPaymentOrders">
            <schedule>*/2 * * * *</schedule>
        </job>
        <job name="ebizmarts_sagepaysuite_check_fraud" instance="Ebizmarts\SagePaySuite\Model\Cron" method="checkFraud">
            <schedule>*/1 * * * *</schedule>
        </job>
        <job name="ebizmarts_sagepaysuite_remove_expired_tokens" instance="Ebizmarts\SagePaySuite\Cron\RemoveExpiredTokens" method="process">
            <schedule>0 0 * * *</schedule>
        </job>
        <job name="ebizmarts_sagepaysuite_try_create_invoice" instance="Ebizmarts\SagePaySuite\Cron\TryCreateInvoice" method="process">
            <schedule>0 * * * *</schedule>
        </job>
        <job name="ebizmarts_sagepaysuite_get_info_sync_from_api" instance="Ebizmarts\SagePaySuite\Cron\GetInfoSyncFromApi" method="process">
            <schedule>0 * * * *</schedule>
        </job>
    </group>
</config>
