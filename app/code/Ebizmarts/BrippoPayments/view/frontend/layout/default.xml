<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" layout="1column" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceBlock name="head.additional">
            <block class="Ebizmarts\BrippoPayments\Block\Head" name="brippo.default.head" template="Ebizmarts_BrippoPayments::default/head.phtml"/>
        </referenceBlock>
        <referenceContainer name="before.body.end">
            <block class="Ebizmarts\BrippoPayments\Block\Express\PaymentElementFailsafe"
                   name="brippo_paymentelement_failsafe"
                   template="Ebizmarts_BrippoPayments::default/payment_element_failsafe.phtml"
                   ifconfig="payment/brippo_payments_express/active"/>
        </referenceContainer>
    </body>
</page>
