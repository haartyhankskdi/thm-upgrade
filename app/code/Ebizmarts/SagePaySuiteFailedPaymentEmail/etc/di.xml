<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd"> 
    <type name="\Ebizmarts\SagePaySuite\Model\PiRequestManagement\EcommerceManagement">
            <plugin name="pi_ecommercemanagement_after"
                    type="Ebizmarts\SagePaySuiteFailedPaymentEmail\Plugin\TrySendPiEmail"
                    sortOrder="1"
                    disabled="false"
            />
    </type>
    <type name="\Ebizmarts\SagePaySuite\Model\PiRequestManagement\ThreeDSecureCallbackManagement">
            <plugin name="pi_3dsecurecallbackmanagement_after"
                    type="Ebizmarts\SagePaySuiteFailedPaymentEmail\Plugin\TrySendPiEmailOnCallback"
                    sortOrder="1"
                    disabled="false"
            />
    </type>

    <preference for="\Ebizmarts\SagePaySuiteFailedPaymentEmail\Api\Email\FailedPaymentInterface" type="\Ebizmarts\SagePaySuiteFailedPaymentEmail\Model\Email\FailedPayment" />

</config>