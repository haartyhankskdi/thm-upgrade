<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <virtualType name="Amasty\ShopByBrandSubscriptionFunctionality\ViewModel\BrandInfoAfterTitle"
                 type="Amasty\ShopByBrandSubscriptionFunctionality\ViewModel\BrandInfo">
        <arguments>
            <argument name="position"
                      xsi:type="const">Amasty\ShopByBrandSubscriptionFunctionality\Model\Source\BrandInfoPosition::AFTER_BRAND_TITLE</argument>
        </arguments>
    </virtualType>
    <virtualType name="Amasty\ShopByBrandSubscriptionFunctionality\ViewModel\BrandInfoAfterDescription"
                 type="Amasty\ShopByBrandSubscriptionFunctionality\ViewModel\BrandInfo">
        <arguments>
            <argument name="position"
                      xsi:type="const">Amasty\ShopByBrandSubscriptionFunctionality\Model\Source\BrandInfoPosition::AFTER_BRAND_DESCRIPTION</argument>
        </arguments>
    </virtualType>
    <virtualType name="Amasty\ShopByBrandSubscriptionFunctionality\ViewModel\BrandInfoAboveFooter"
                 type="Amasty\ShopByBrandSubscriptionFunctionality\ViewModel\BrandInfo">
        <arguments>
            <argument name="position"
                      xsi:type="const">Amasty\ShopByBrandSubscriptionFunctionality\Model\Source\BrandInfoPosition::ABOVE_PAGE_FOOTER</argument>
        </arguments>
    </virtualType>
    <virtualType name="Amasty\ShopByBrandSubscriptionFunctionality\ViewModel\BrandInfoProductPageInfoTab"
                 type="Amasty\ShopByBrandSubscriptionFunctionality\ViewModel\BrandInfo">
        <arguments>
            <argument name="position"
                      xsi:type="const">Amasty\ShopByBrandSubscriptionFunctionality\Model\Source\BrandInfoPosition::PRODUCT_PAGE_INFO_TAB</argument>
        </arguments>
    </virtualType>

    <type name="Magento\Catalog\Block\Product\View\Attributes">
        <plugin name="Amasty_ShopByBrandSubscriptionFunctionality::AddBrandInfo"
                type="Amasty\ShopByBrandSubscriptionFunctionality\Plugin\Catalog\Block\Product\View\Attributes\AddBrandInfo"/>
    </type>
</config>
