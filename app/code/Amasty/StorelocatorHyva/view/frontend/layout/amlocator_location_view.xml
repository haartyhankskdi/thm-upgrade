<page
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    layout="1column"
    xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd"
>
    <update handle="hyva_modal"/>

    <head>
        <css src="Amasty_StorelocatorHyva::vendor/fancybox/fancybox.css"/>
        <remove src="Amasty_Storelocator::vendor/fancybox/jquery.fancybox.min.css"/>
    </head>

    <body>
        <referenceBlock name="location">
            <block
                class="Amasty\Storelocator\Block\View\Location"
                name="store.page.script"
                template="Amasty_Storelocator::js/store-page.phtml"
            />
        </referenceBlock>
    </body>
</page>
