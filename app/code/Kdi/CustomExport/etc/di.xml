<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <virtualType name="MYCustomExportGridFilterPool" type="Magento\Framework\View\Element\UiComponent\DataProvider\FilterPool">
        <arguments>
            <argument name="appliers" xsi:type="array">
                <item name="regular" xsi:type="object">Magento\Framework\View\Element\UiComponent\DataProvider\RegularFilter</item>
                <item name="fulltext" xsi:type="object">Magento\Framework\View\Element\UiComponent\DataProvider\FulltextFilter</item>
            </argument>
        </arguments>
    </virtualType>
    <virtualType name="MYCustomExportGridFilterPool" type="Magento\Framework\View\Element\UiComponent\DataProvider\DataProvider">
        <arguments>
            <argument name="collection" xsi:type="object" shared="true">Kdi\CustomExport\Model\ResourceModel\CustomExport\Collection</argument>
            <argument name="filterPool" xsi:type="object" shared="true">MYCustomExportGridFilterPool</argument>
        </arguments>
    </virtualType>
    <type name="Kdi\CustomExport\Model\ResourceModel\CustomExport\Grid\Collection">
	    <arguments>
	        <argument name="mainTable" xsi:type="string">sales_order</argument>
	        <argument name="eventPrefix" xsi:type="string">kdi_customExport_grid_collection</argument>
	        <argument name="eventObject" xsi:type="string">customexport_grid_collection</argument>
	        <argument name="resourceModel" xsi:type="string">Kdi\CustomExport\Model\ResourceModel\CustomExport</argument>
	    </arguments>
	</type>
    <type name="Magento\Framework\View\Element\UiComponent\DataProvider\CollectionFactory">
        <arguments>
            <argument name="collections" xsi:type="array">
                <item name="customexport_customexport_index_listing_data_source" xsi:type="string">Kdi\CustomExport\Model\ResourceModel\CustomExport\Grid\Collection</item>
            </argument>
        </arguments>
    </type>
    <preference for="Magento\Ui\Model\Export\ConvertToCsv" type="Kdi\CustomExport\Model\Export\ConvertToCsv" />
</config>