<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Store:etc/config.xsd">
    <default>
        <rewardpoints>
            <module>
                <user_guide>magento/reward-points-ultimate</user_guide>
            </module>
            <earning>
                <earning_point_with_coupon>0</earning_point_with_coupon>
            </earning>
            <spending>
                <spending_point_with_coupon>0</spending_point_with_coupon>
            </spending>
            <behavior>
                <facebook>
                    <enabled>0</enabled>
                    <pages_display>cms_index_index,catalog_category_view,catalog_product_view</pages_display>
                </facebook>
                <twitter>
                    <enabled>0</enabled>
                    <pages_display>cms_index_index,catalog_category_view,catalog_product_view</pages_display>
                </twitter>
            </behavior>
            <referrals>
                <general>
                    <email>rewardpoints_referrals_general_email</email>
                </general>
                <url_key>
                    <param>2</param>
                </url_key>
            </referrals>
            <milestone>
                <enabled>1</enabled>
                <source>0,1,2,3</source>
                <email>0</email>
                <template>rewardpoints_milestone_template</template>
                <background_color>#c4c4c4</background_color>
                <range_color>#01007F</range_color>
            </milestone>
        </rewardpoints>
    </default>
</config>
