<?php /** @var Mageplaza\RewardPointsUltimate\Block\Referral\Invitee $block */
$invitees = $block->getInvitees(); ?>
<?php if (count($invitees)) : ?>
    <div class="block mp-invitee col-mp mp-12 mp-md-12 mp-sm-12 mp-xs-12">
        <div class="block-title">
            <h3><?= $block->escapeHtml(__('Your Invitee')) ?></h3>
        </div>
        <div class="box-content">
            <div class="history">
                <table class="data table " id="transactions-history">
                    <thead>
                    <tr>
                        <th scope="col" class="col"><?= $block->escapeHtml(__('ID')) ?></th>
                        <th scope="col" class="col"><?= $block->escapeHtml(__('Receiver')) ?></th>
                        <th scope="col" class="col"><?= $block->escapeHtml(__('Receiver earn')) ?></th>
                        <th scope="col" class="col"><?= $block->escapeHtml(__('Receiver discount')) ?></th>
                        <th scope="col" class="col"><?= $block->escapeHtml(__('You earn')) ?></th>
                        <th scope="col" class="col"><?= $block->escapeHtml(__('Date')) ?></th>
                    </tr>
                    </thead>
                    <tbody>
                    <?php foreach ($invitees as $invitee) : ?>
                        <tr>
                            <td class="col"><?= $block->escapeHtml($invitee->getId()) ?></td>
                            <td class="col"><?= $block->escapeHtml($invitee->getInvitedEmail()) ?></td>
                            <td class="col"><?= $block->escapeHtml($invitee->getInvitedEarn()) ?></td>
                            <td class="col"><?= $block->formatPrice($invitee->getInvitedDiscount()) ?></td>
                            <td class="col"><?= $block->escapeHtml($invitee->getReferralEarn()) ?></td>
                            <td class="col"><?= $block->escapeHtml($block->formatDate($invitee->getCreatedAt())) ?></td>
