<script type="text/javascript">
    require(['jquery'], function ($) {
        $(document).ready(function () {
            isDislayInviteMessage();
            var btnCopy = $('.url_and_code .copy');

            $('#send-by').on('change', function () {
                isDislayInviteMessage();
            });

            btnCopy.hover(function () {
                $(this).find('.mp-copied-icon').hide();
                $(this).find('.mp-copy-icon').show();
                $(this).find('.mp-copied-tooltip').css({
                    'visibility': 'hidden',
                    'opacity': '0'
                });
            });

            btnCopy.click(function () {
                $(this).siblings('.mp-input').select();
                document.execCommand("copy");
                $(this).find('.mp-copied-tooltip').css({
                    'visibility': 'visible',
                    'opacity': '1'
                });
                $(this).find('.mp-copy-icon').hide();
                $(this).find('.mp-copied-icon').show();
            });

            function isDislayInviteMessage() {
                if ($('#send-by').val() === 'store') {
                    $('.invite-message').hide();
                } else {
                    $('.invite-message').show();
                }
            }
        });
    });
</script>

