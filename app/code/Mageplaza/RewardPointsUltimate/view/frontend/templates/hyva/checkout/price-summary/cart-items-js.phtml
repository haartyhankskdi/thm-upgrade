declare(strict_types=1);

use Hyva\Theme\Model\ViewModelRegistry;

/** @var ViewModelRegistry $viewModels */

$isHaveCsp = class_exists(\Hyva\Theme\ViewModel\HyvaCsp::class);
$hyvaCsp   = '';
if ($isHaveCsp) {
    $hyvaCsp = $viewModels->require(\Hyva\Theme\ViewModel\HyvaCsp::class);
}
?>
<script>
    function mpRwPriceSummaryCartItems () {
        return hyva.createBooleanObject('visible', this.$wire.expand, {
            applyDownRotateClass () {
                return {
                    'transform rotate-180': this.visible()
                }
            }
        })
    }

    window.addEventListener('alpine:init', () => {
        Alpine.data('mpRwPriceSummaryCartItems', mpRwPriceSummaryCartItems)
    }, {once: true})
</script>
<?php if ($isHaveCsp) {
    $hyvaCsp->registerInlineScript();
} ?>
