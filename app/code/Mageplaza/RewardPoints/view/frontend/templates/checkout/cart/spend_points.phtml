                            <div class="reward-slider-content">
                                <div class="reward-spending-slider">
                                    <div class="range">
                                        <div class="field">
                                            <div class="value left" x-text="selectedRule.min"></div>
                                            <input type="range" class="reward-range-slider"
                                                   min="<?= /* @noEscape */
                                                   $minSpendingPoint ?>" max="<?= /* @noEscape */
                                            $maxSpendingPoint ?>"
                                                   value="<?= /* @noEscape */
                                                   $spentPoints ? $spentPoints : 0 ?>" steps="1"
