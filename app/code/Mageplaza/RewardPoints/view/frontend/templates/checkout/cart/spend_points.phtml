/** @var Template $block */
/** @var Escaper $escaper */

/** @var Data $helper */
$helper          = $this->helper(Data::class);
$calculation     = $this->helper(Calculation::class);
$shippingAddress = $helper->getQuote()->getShippingAddress();
$address         = [
        'countryId' => $shippingAddress->getCountryId(),
        'region'    => $shippingAddress->getRegion(),
        'regionId'  => $shippingAddress->getRegionId(),
        'postcode'  => $shippingAddress->getPostcode()
];

$isDisabledSpending = $helper->isDisabledSpending();
$spentPoints        = $helper->getQuote()->getMpRewardSpent();
$maxSpendingByRate  = 0;
$maxSpendingPoint   = 0;
$minSpendingPoint   = 0;
if ($helper->getQuote()->getCustomerId()) {
    $maxSpendingByRate = $calculation->getMaxSpendingPointsByRate($helper->getQuote());
    $maxSpendingPoint  = $calculation->getMaxSpendingPoints($maxSpendingByRate);
    $rate              = $calculation->getSpendingRateByQuote($helper->getQuote());
    $minSpendingPoint  = $rate->getMinPoint();
}
