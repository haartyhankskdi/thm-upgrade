        <script>
            function rewardPoints () {
                var points = JSON.parse(window.checkoutConfig.totalsData.extension_attributes.reward_points);

                return {
                    open: false,
                    isLoading: false,
                    cart: {},
                    totalsData: window.checkoutConfig.totalsData,
                    quoteData: window.checkoutConfig.quoteData,
                    customerData: window.checkoutConfig.customerData,
                    spendingConfig: points.spending,
                    isCheckoutCart: points.isCheckoutCart,
                    rules: function () {
                        return points.spending.rules ?? 0;
                    },
                    selectedRule: {},
                    pointSpent: null,
                    canVisibleSpendPoints: true,
                    isDisplaySlider: true,
                    useMaxPoint: false,
                    pauseSubscribe: false,
                    slider: null,
                    oldValue: null,
                    isChangeRule: false,
                    dispatch: null,
                    selectedRuleId: null,
                    spendingPoints: function (pointSpent, ruleId) {
                        debugger

                        this.dispatch('update-totals-start', {});
                        var earningPoint,
                            payload = {
                                points: pointSpent || 0,
                                ruleId: ruleId || '',
                                addressInformation: {}
                            };

                        const selectedShippingMethod = window.checkoutConfig.selectedShippingMethod;
                        payload.addressInformation   = {address: <?= /* @noEscape */ $helper::jsonEncode($address) ?>};
                        if (selectedShippingMethod && selectedShippingMethod.method_code) {
                            payload.addressInformation['shipping_method_code']  = selectedShippingMethod.method_code;
                            payload.addressInformation['shipping_carrier_code'] = selectedShippingMethod.carrier_code;
                        }
                        fetch(BASE_URL + 'rest/' + CURRENT_STORE_CODE + '/V1/carts/mine/mpreward' + '?form_key=' + hyva.getFormKey(), {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                                'X-Requested-With': 'XMLHttpRequest'
                            },
                            body: JSON.stringify(payload)
                        }).then(response => response.json())
                        .then((result) => {
                            const browserStorage = hyva.getBrowserStorage();
                            if (browserStorage) {
                                browserStorage.removeItem('mage-cache-storage');
                            }
                            this.dispatch('update-totals', {data: result});
                            earningPoint = result.total_segments.find((segment) => segment.code === 'mp_reward_earn');
                            if (earningPoint && earningPoint.value) {
                                this.cart.rewardEarn = this.format(earningPoint.value);
                            } else {
                                this.cart.rewardEarn = 0;
                            }
                        }).catch(function (error) {
                            console.log(error.message);
                            typeof window.dispatchMessages !== "undefined" && window.dispatchMessages(
                                [{type: "error", text: error}], 3000
                            );
                        }).finally(() => {
                                this.dispatch('update-totals-end', {});
                            }
                        );
                    },

                    balanceFormatted: function () {
                        var label = 'You have %s';
                        return label.replace('%s', '<strong>' + this.format(points.balance) + '</strong>');
                    },

                    format: function (point) {
                        if (parseInt(point) > 1) {
                            return points.pattern.plural.replace('{point}', point);
                        }

                        return points.pattern.single.replace('{point}', point);
                    },

                    init ($dispatch) {
                        this.dispatch = $dispatch;
                    },

                    initData: function (data) {
                        var slidePoint;
                        slidePoint = this.spendingConfig.pointSpent;
                        if (data.cart) {
                            this.cart = data.cart;
                        }
                        if (this.selectedRule &&
                            Number(slidePoint) > Number(this.selectedRule.max) &&
                            this.selectedRule.isDisplaySlider
                        ) {
                            slidePoint = this.selectedRule.max;
                        }

                        if (this.selectedRule &&
                            this.selectedRule.isDisplaySlider
                        ) {
                            this.isDisplaySlider = this.selectedRule.isDisplaySlider;
                        }
                        this.pointSpent = slidePoint;
                        if (this.spendingConfig.ruleApplied) {
                            this.rules().forEach(rule => {
                                if (rule.id === this.spendingConfig.ruleApplied) {
                                    this.selectedRule = rule;
                                    return false;
                                }
                            });
                        }
                        if (this.rules().length === 1 && typeof this.rules()[0]['id'] !== 'undefined' && this.rules()[0]['id'] === 'rate') {
                            this.spendingConfig.ruleApplied = this.rules()[0]['id'];
                        }
                        this.initSelectedRule(this.spendingConfig.ruleApplied);
                    },

                    changePointSpent: function (event) {
                        var rule,
                            value,
                            newValue;

                        if (event) {
                            rule = this.selectedRule;

                            if (this.pointSpent && parseInt(this.pointSpent)) {
                                value = parseInt(this.pointSpent);

                                if (value < rule.min) {
                                    newValue = rule.min;
                                } else if (value > rule.max) {
                                    newValue = rule.max;
                                } else {
                                    newValue = value;
                                }
                            } else {
                                newValue = rule.min;
                            }

                            const inputSlider = document.querySelector(".reward-range-slider");
                            if (newValue !== inputSlider.value) {
                                this.updateValueOnSlider(newValue);
                            }
                        }
                    },

                    changeMaxPoint: function (event) {
                        var newValue = 0;

                        if (event) {
                            newValue = !this.useMaxPoint ? this.selectedRule.max : this.selectedRule.min;
                            this.updateValueOnSlider(newValue);
                        }
                    },

                    updateValueOnSlider: function (newValue) {
                        this.pointSpent = newValue;
                        this.spendingPoints(this.pointSpent, this.selectedRule.id);
                    },

                    changeRule: function (ruleId) {
                        if (ruleId) {
                            this.initSelectedRule(ruleId);
                            this.isChangeRule = true;
                        }
                    },

                    initSelectedRule: function (ruleId) {
                        var selectedRule;

                        if (this.rules() && this.rules().length) {
                            if (ruleId) {
                                this.rules().forEach(rule => {
                                    if (rule.id === ruleId) {
                                        selectedRule = rule;
                                        return false;
                                    }
                                });
                            }
                            if (ruleId === 'no_apply' || !selectedRule) {
                                this.selectedRule    = this.rules()[0];
                                this.isDisplaySlider = false;
                            }
                            if (JSON.stringify(selectedRule) !== JSON.stringify(this.selectedRule)) {
                                this.pointSpent   = 0;
                                this.selectedRule = selectedRule;
                            }
                            this.isDisplaySlider = selectedRule.isDisplaySlider;

                        } else {
                            this.selectedRule    = null;
                            this.isDisplaySlider = false;
                        }
                        if (this.selectedRule && selectedRule){
                            this.spendingPoints(this.pointSpent, this.selectedRule.id);
                        }

                        return this;
                    },

                    initSlider: function () {
                        window.mpRewardPoints = 0;
                        var isUseMaxPointByDefault;

                        this.isLoading = true;
                        this.checkMaxPointByAction();
                        this.sendUpdateSpentPoints();
                        this.updateSlider();
                        isUseMaxPointByDefault = this.pointSpent === null && this.spendingConfig.useMaxPoints;
                        if (isUseMaxPointByDefault) {
                            this.pointSpent = this.selectedRule.max;
                            this.updateSlider();
                        }
                    },

                    updateSlider: function () {
                        var rule          = this.selectedRule;
                        const inputSlider = document.querySelector(".reward-range-slider");
                        if (rule) {
                            inputSlider.max  = rule.max;
                            inputSlider.min  = rule.min;
                            inputSlider.step = rule.step;
                        }
                    },

                    sendUpdateSpentPoints: function () {
                        if (this.pointSpent !== this.oldValue || this.isChangeRule) {
                            this.updateSpendPoints();
                            this.oldValue = this.pointSpent;
                        }
                    },

                    checkMaxPointByAction: function () {
                        this.useMaxPoint = parseInt(this.pointSpent) === parseInt(this.selectedRule.max);
                    },

                    updateSpendPoints: function () {
                        if (isNaN(this.pointSpent)) {
                            this.pointSpent = 0;
                        }
                        this.spendingPoints(this.pointSpent, this.selectedRule.id);
                    },

                    getCollapsible: function () {
                        return this.isCheckoutCart ? '' : {'collapsible': {'openedState': '_active'}};
                    }
                }
            };
        </script>
    <?php endif; ?>
<?php endif; ?>
