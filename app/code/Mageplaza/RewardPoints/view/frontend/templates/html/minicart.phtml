    <div class="mp-reward-cart">
        <template x-if="cart && cart.rewardEarn">
            <div>
                <span style="float: left; margin-left: 6%; margin-right: 1%; margin-top: 0.5%"><?= $helperPoints->getIconHtml() ?></span>
                <span><?= $escaper->escapeHtml(__('Checkout now to earn')) ?></span>
                <strong class="mp-rw-highlight" x-text="cart.rewardEarn"></strong>
            </div>
        </template>
    </div>
<?php endif; ?>
