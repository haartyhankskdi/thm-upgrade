                        </div>
                        <div class="text-sm px-0 py-2 md:p-2 lg:flex items-center <?= $i % 2 === 0 ? '' : ' ' ?>">
                            <span class="md:hidden  font-bold text-base">Status : </span>
                            <?= $escaper->escapeHtml($transaction->getStatusLabel()) ?>
                        </div>
                        <div class="text-sm px-0 py-2 md:p-2 lg:flex items-center action-box <?= $i % 2 === 0 ? '' : ' ' ?>">
