/**@var \Mageplaza\RewardPoints\Block\Account\Dashboard\Exchange $block */
if ($block->canDisplay()) :
    $earningRate = $block->getEarningRate();
    $spendingRate = $block->getSpendingRate();
    ?>
    <div class="block-container block reward-information mp-clear">
        <div class="block-title !border-0 text-[28px] text-black font-semibold mb-2"><?= $block->escapeHtml(__('Reward information')) ?></div>
        <div class="block-content">
            <?php if ($earningRate || $spendingRate) : ?>
                <div class="box box-exchange text-babe text-black font-normal leading-7">
                    <strong class="box-title">
                        <span><?= $block->escapeHtml(__('Current exchange rates:')) ?></span>
                    </strong>
                    <div class="box-content">
                        <?php if ($earningRate) : ?>
                            <div class="earning-rate">
                                <span>
                                    <?= /** noEscape */ __(
                                        'Each %1 spent for your order will earn %2.',
                                        '<strong>' . $block->convertPrice($earningRate->getMoney()) . '</strong>',
                                        '<strong>' . $block->formatPoint($earningRate->getPoints()) . '</strong>'
                                    ) ?>
                                </span>
                            </div>
                        <?php endif; ?>
                        <?php if ($spendingRate) : ?>
                            <div class="spending-rate">
                                <span>
                                    <?= /** noEscape */ __(
                                        'Each %1 can be redeemed for %2.',
                                        '<strong>' . $block->formatPoint($spendingRate->getPoints()) . '</strong>',
                                        '<strong>' . $block->convertPrice($spendingRate->getMoney()) . '</strong>'
                                    ) ?>
                                </span>
                            </div>
                        <?php endif; ?>
                    </div>
                </div>
            <?php endif; ?>
            <?php if ($maxPoints = $block->getMaxPointPerCustomer()) : ?>
                <div class="box box-point-limit">
                    <strong class="box-title !border-0 text-[28px] text-black font-semibold mb-2">
                        <span><?= $block->escapeHtml(__('Balance limitation:')) ?></span>
                    </strong>
                    <div class="box-content point">
                        <span><?= $block->escapeHtml(__('Balance is limited at %1', $block->formatPoint($maxPoints))) ?></span>
                    </div>
                </div>
            <?php endif; ?>
            <?php if ([$points, $dayLabel, $numberDaysExpire, $expirationDate] = $block->getFirstExpire()) : ?>
                <?php if ($points > 0 && $numberDaysExpire >= 0) : ?>
                    <div class="box box-point-expired">
                        <strong class="box-title !border-0 text-[28px] text-black font-semibold mb-2">
                            <span><?= $block->escapeHtml(__('Expiring Points:')) ?></span>
                        </strong>
                        <div class="box-content expired">
                            <span>
                                <strong><?= /** @noEscape */ $block->formatPoint($points) ?> </strong>
                                <?php if ($dayLabel != 'today') : ?>
                                <?= $block->escapeHtml(__('will be expired after')) ?>
                                <strong style="color: red"><?= /* @noEscape */ $numberDaysExpire . ' ' . $dayLabel ?></strong> (<?= /** @noEscape */ $expirationDate ?>).
                                <?php else : ?>
                                    <?= $block->escapeHtml(__('will be expired'))?>
                                    <strong style="color: red"> <?= /* @noEscape */ $dayLabel ?></strong> (<?= /** @noEscape */ $expirationDate ?>).
                                <?php endif; ?>
                            </span>
                        </div>
                    </div>
                <?php endif; ?>
            <?php endif; ?>
            <?= /** @noEscape */ $block->getChildHtml() ?>
        </div>
    </div>
<?php endif; ?>
