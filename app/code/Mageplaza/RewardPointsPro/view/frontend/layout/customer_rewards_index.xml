<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" layout="2columns-left" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <update handle="rewards_account"/>
    <body>
        <referenceBlock name ="reward_dashboard" class="Mageplaza\RewardPointsPro\Block\Account\Dashboard">
            <action method="setTemplate">
                <argument name="template" xsi:type="string">Mageplaza_RewardPointsPro::account/dashboard.phtml</argument>
            </action>
        </referenceBlock>
        <referenceBlock name="reward_dashboard_exchange">
            <block class="Mageplaza\RewardPointsPro\Block\Account\Dashboard\Hold" name="reward_dashboard_exchange_hold" template="Mageplaza_RewardPointsPro::account/dashboard/hold.phtml"/>
        </referenceBlock>
    </body>
</page>
