    <!-- Banner widget -->
    <widget class="Hyva\Widgets\Block\Widgets\Banner" id="hyva_banner" placeholder_image="Hyva_Widgets::images/banner.png">
        <label>Hyva Banner</label>
        <description translate="true">Hyva banner</description>
        <parameters>
            <parameter name="hyva_banner_content_admin_title" xsi:type="block" required="false" visible="true"
                       sort_order="0">
                <description>
                    <![CDATA[<hr style="margin:40px 0;" /><h1 style="text-align: left; margin: 40px 0">Content</h1>]]></description>
                <block class="Hyva\Widgets\Block\Adminhtml\Renderer\WidgetSectionTitle"/>
            </parameter>
            <parameter name="hyva_banner_image" xsi:type="block" required="false" visible="true" sort_order="10">
                <label translate="true">Banner image</label>
                <description>Images are not resized on the frontend by default, be aware of file sizes!</description>
                <block class="Hyva\Widgets\Block\WidgetConfigs\ImageField">
                    <data>
                        <item name="button" xsi:type="array">
                            <item name="open" xsi:type="string">Choose Image...</item>
                        </item>
                    </data>
                </block>
            </parameter>
            <parameter name="hyva_banner_image_width" sort_order="12" visible="true" xsi:type="text">
                <label>Banner image width</label>
                <description>Insert the original width of the image to help the browser determine the aspect ratio early.</description>
                <value>720</value>
            </parameter>
            <parameter name="hyva_banner_image_height" sort_order="14" visible="true" xsi:type="text">
                <label>Banner image height</label>
                <description>Insert the original height of the image to help the browser determine the aspect ratio early.</description>
                <value>384</value>
            </parameter>
            <parameter name="hyva_banner_title" sort_order="20" visible="true" xsi:type="text">
                <label>Banner title</label>
                <description>Enter any title here.</description>
            </parameter>
            <parameter name="hyva_banner_text" sort_order="30" visible="true" xsi:type="block">
                <label>Banner text</label>
                <description>Enter a paragraph of plain-text here</description>
                <block class="Hyva\Widgets\Block\WidgetConfigs\TextArea"/>
            </parameter>
            <parameter name="hyva_banner_button_label" sort_order="40" visible="true" xsi:type="text">
                <label>Banner button label</label>
                <description>Banner button label</description>
            </parameter>
            <parameter name="hyva_banner_button_url" sort_order="50" visible="true" xsi:type="text">
                <label>Banner button url</label>
                <description>Banner button url</description>
            </parameter>
            <parameter name="hyva_banner_content_alignment" xsi:type="select" required="false"
                       source_model="Hyva\Widgets\Block\WidgetConfigs\CaptionAlignment" visible="true" sort_order="60">
                <label translate="true">Banner content text alignment</label>
                <description>Banner content text alignment can be left, center or right. Default position is left
                </description>
            </parameter>
            <parameter name="hyva_banner_content_text_color" sort_order="70" visible="true" xsi:type="block">
                <label>Content text color</label>
                <description>Content text color</description>
                <block class="Hyva\Widgets\Block\WidgetConfigs\Color">
                    <data>
                        <item name="colorpickerid" xsi:type="string">hyva_banner_content_text_color</item>
                    </data>
                </block>
            </parameter>
            <parameter name="hyva_banner_container_background" sort_order="80" visible="true" xsi:type="block">
                <label>Content container background</label>
                <description>Content container background</description>
                <block class="Hyva\Widgets\Block\WidgetConfigs\Color">
                    <data>
                        <item name="colorpickerid" xsi:type="string">hyva_banner_container_background</item>
                    </data>
                </block>
            </parameter>
            <parameter name="hyva_banner_content_container" sort_order="90" visible="true" xsi:type="select">
                <label>Container</label>
                <description>
                    <![CDATA[Apply container to the widget content. This uses following native container <a href="https://tailwindcss.com/docs/container</description">sizes</a>. If different needed should be overriden in hyva themes tailwind.config.js]]></description>
                <options>
                    <option name="remove-container" value="0">
                        <label translate="true">Remove container</label>
                    </option>
                    <option name="add-container" value="1">
                        <label translate="true">Add container</label>
                    </option>
                </options>
            </parameter>

            <parameter name="hyva_banner_inner_content_container" sort_order="100" visible="true" xsi:type="select">
                <label>Banner inner content container</label>
                <description>
                    <![CDATA[Apply container to the widget inner content. We would use this with removed container on the whole widget to achieve fluid 100% design of background and contained data. This uses following native container <a href="https://tailwindcss.com/docs/container</description">sizes</a>. If different needed should be overriden in hyva themes tailwind.config.js]]></description>
                <options>
                    <option name="remove-container" value="0">
                        <label translate="true">Remove container</label>
                    </option>
                    <option name="add-container" value="1">
                        <label translate="true">Add container</label>
                    </option>
                </options>
            </parameter>


            <parameter name="hyva_banner_styles_admin_title" xsi:type="block" required="false" visible="true"
                       sort_order="200">
                <description>
                    <![CDATA[<hr style="margin:40px 0;" /><h1 style="text-align: left; margin: 40px 0">Banner styles</h1>]]></description>
                <block class="Hyva\Widgets\Block\Adminhtml\Renderer\WidgetSectionTitle"/>
            </parameter>
            <parameter name="hyva_banner_layout" xsi:type="select" visible="true" sort_order="210">
                <label translate="true">Banner layout</label>
                <description>Different banner layouts</description>
                <options>
                    <option name="full-width" value="full-width" selected="true">
                        <label translate="true">Full width</label>
                    </option>
                    <option name="half-left-caption" value="half-left-caption" selected="true">
                        <label translate="true">Half left caption</label>
                    </option>
                    <option name="half-right-caption" value="half-right-caption" selected="true">
                        <label translate="true">Half right caption</label>
                    </option>
                </options>
            </parameter>
            <parameter name="hyva_banner_shading" xsi:type="select" visible="true" sort_order="220">
                <label translate="true">Shading</label>
                <description>Shading over the image for better visibility. Default value is No</description>
                <options>
                    <option name="no" value="0" selected="true">
                        <label translate="true">No</label>
                    </option>
                    <option name="yes" value="1">
                        <label translate="true">Yes</label>
                    </option>
                </options>
            </parameter>
            <parameter name="hyva_banner_shading_color" sort_order="230" visible="true" xsi:type="block">
                <label>Shading color</label>
                <description>Shading color</description>
                <block class="Hyva\Widgets\Block\WidgetConfigs\Color">
                    <data>
                        <item name="colorpickerid" xsi:type="string">hyva_banner_shading_color</item>
                    </data>
                </block>
            </parameter>

            <parameter name="hyva_banner_admin_animations_title" xsi:type="block" required="false" visible="true"
                       sort_order="300">
                <description>
                    <![CDATA[<hr style="margin:40px 0;" /><h1 style="text-align: left; margin: 40px 0">Animations</h1>]]></description>
                <block class="Hyva\Widgets\Block\Adminhtml\Renderer\WidgetSectionTitle"/>
            </parameter>

            <parameter name="hyva_banner_fade_animations" xsi:type="select" required="false"
                       source_model="Hyva\Widgets\Block\WidgetConfigs\FadeAnimations" visible="true" sort_order="310">
                <label translate="true">Banner fade animations</label>
                <description>Loading animation for the whole widget. Default is "No animation".</description>
            </parameter>

            <parameter name="spacing" xsi:type="block" required="false" visible="true" sort_order="400">
                <description>
                    <![CDATA[<hr style="margin:40px 0;" /><h1 style="text-align: left; margin: 40px 0">Banner spacing</h1>]]></description>
                <block class="Hyva\Widgets\Block\Adminhtml\Renderer\WidgetSectionTitle"/>
            </parameter>

            <parameter name="hyva_banner_margin" xsi:type="text" visible="true" sort_order="410">
                <label translate="true">Hyva banner margin (Tailwind Classes)</label>
                <description>
                    <![CDATA[Add styling to the main element. For whitespace around the element, look <a href="https://tailwindcss.com/docs/margin" target="_blank">here</a>. E.g. "mt-8 mb-8 mr-4 ml-4". Works with other Tailwind classes like "card rounded shadow" as well.]]></description>
            </parameter>
        </parameters>

    </widget>


