<widgets xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Widget:etc/widget.xsd">

    <widget class="Hyva\Widgets\Block\Widgets\Category" id="hyva_category"
            placeholder_image="Hyva_Widgets::images/category.png">
        <label>Hyva Category Products</label>
        <description translate="true">Lists products from a given category</description>
        <parameters>

            <parameter name="hvya_category_content_admin_title" xsi:type="block" required="false" visible="true"
                       sort_order="0">
                <description>
                    <![CDATA[<hr style="margin:40px 0;" /><h1 style="text-align: left; margin: 40px 0">Content</h1>]]></description>
                <block class="Hyva\Widgets\Block\Adminhtml\Renderer\WidgetSectionTitle"/>
            </parameter>
            <parameter name="hyva_category_title" sort_order="10" visible="true" xsi:type="text">
                <label>Widget title</label>
            </parameter>
            <parameter name="hyva_category_content" sort_order="20" visible="true" xsi:type="block">
                <label>Content</label>
                <description>Enter any content here.</description>
                <block class="Hyva\Widgets\Block\WidgetConfigs\Wysiwyg"/>
            </parameter>
            <parameter name="hyva_category_container" sort_order="30" visible="true" xsi:type="select">
                <label>Container</label>
                <description>
                    <![CDATA[Apply container to the widget content. This uses following native container <a href="https://tailwindcss.com/docs/container</description">sizes</a>. If different needed should be overriden in hyva themes tailwind.config.js]]></description>
                <options>
                    <option name="add-container" value="true">
                        <label translate="true">Add container</label>
                    </option>
                    <option name="remove-container" value="false">
                        <label translate="true">Remove container</label>
                    </option>
                </options>
            </parameter>
            <parameter name="hyva_category_background" sort_order="40" visible="true" xsi:type="block">
                <label>Category container background</label>
                <description>Category container background</description>
                <block class="Hyva\Widgets\Block\WidgetConfigs\Color">
                    <data>
                        <item name="colorpickerid" xsi:type="string">hyva_category_background</item>
                    </data>
                </block>
            </parameter>
            <parameter name="hyva_category_content_padding" xsi:type="text" visible="true" sort_order="50">
                <label translate="true">Hyva content padding</label>
                <description>
                    <![CDATA[Inside spacing on top, left, bottom, right. More details can be found <a href="https://tailwindcss.com/docs/padding" target="_blank">here</a>. E.g. "pt-8 pb-8 pl-4 pr-4" or "py-6 px-8". Multiple entries allowed according to tailwind standards.]]></description>
            </parameter>


            <parameter name="hyva_category_list_title" xsi:type="block" required="false" visible="true" sort_order="100">
                <description>
                    <![CDATA[<hr style="margin:40px 0;" /><h1 style="text-align: left; margin: 40px 0">Category Product list</h1>]]></description>
                <block class="Hyva\Widgets\Block\Adminhtml\Renderer\WidgetSectionTitle"/>
            </parameter>
            <parameter name="hyva_category_list" xsi:type="select" required="false"
                       source_model="Hyva\Widgets\Block\WidgetConfigs\CategoryList" visible="true" sort_order="110">
                <label translate="true">Category select</label>
                <description>This will show category products</description>
            </parameter>

            <parameter name="hyva_category_limit" xsi:type="text" required="false" visible="true" sort_order="120">
                <label translate="true">Number of Products to display</label>
                <value>16</value>
            </parameter>

            <parameter name="hyva_category_sort_by" xsi:type="select" required="false"
                       source_model="Magento\Catalog\Model\Category\Attribute\Source\Sortby" visible="true" sort_order="130">
                <label translate="true">Sort By</label>
            </parameter>

            <parameter name="hyva_category_sort_direction" xsi:type="select" required="false"
                       source_model="Hyva\Widgets\Block\WidgetConfigs\SortDirection" visible="true" sort_order="130">
                <label translate="true">Sort Direction</label>
            </parameter>

            <parameter name="hyva_category_animations_admin_title" xsi:type="block" required="false" visible="true"
                       sort_order="200">
                <description>
                    <![CDATA[<hr style="margin:40px 0;" /><h1 style="text-align: left; margin: 40px 0">Animations</h1>]]></description>
                <block class="Hyva\Widgets\Block\Adminhtml\Renderer\WidgetSectionTitle"/>
            </parameter>
            <parameter name="hyva_category_fade_animations" xsi:type="select" required="false"
                       source_model="Hyva\Widgets\Block\WidgetConfigs\FadeAnimations" visible="true" sort_order="210">
                <label translate="true">Category fade animations</label>
                <description>Loading animation for the whole widget. Default is "No animation".</description>
            </parameter>

            <parameter name="hyva_category_type_title" xsi:type="block" required="false" visible="true" sort_order="300">
                <description>
                    <![CDATA[<hr style="margin:40px 0;" /><h1 style="text-align: left; margin: 40px 0">Widget type</h1>]]></description>
                <block class="Hyva\Widgets\Block\Adminhtml\Renderer\WidgetSectionTitle"/>
            </parameter>
            <parameter name="hyva_category_type" xsi:type="select" visible="true" sort_order="310">
                <label translate="true">Display Type</label>
                <description>Slider or grid functionality.</description>
                <options>
                    <option name="slider" value="hyva_slider" selected="true">
                        <label translate="true">Hyvä Slider</label>
                    </option>
                    <option name="splide" value="splide_slider">
                        <label translate="true">SplideJS Slider</label>
                    </option>
                    <option name="grid" value="grid">
                        <label translate="true">Grid</label>
                    </option>
                </options>
            </parameter>


            <parameter name="hyva_category_spacing_admin_title" xsi:type="block" required="false" visible="true"
                       sort_order="400">
                <description>
                    <![CDATA[<hr style="margin:40px 0;" /><h1 style="text-align: left; margin: 40px 0">Spacing</h1>]]></description>
                <block class="Hyva\Widgets\Block\Adminhtml\Renderer\WidgetSectionTitle"/>
            </parameter>
            <parameter name="hyva_category_padding" xsi:type="text" visible="true" sort_order="410">
                <label translate="true">Hyva category section padding</label>
                <description>
                    <![CDATA[Inside spacing on top, left, bottom, right. More details can be found <a href="https://tailwindcss.com/docs/padding" target="_blank">here</a>. E.g. "pt-8 pb-8 pl-4 pr-4" or "py-6 px-8". Multiple entries allowed according to tailwind standards.]]></description>
            </parameter>
            <parameter name="hyva_category_margin" xsi:type="text" visible="true" sort_order="420">
                <label translate="true">Hyva category section margin</label>
                <description>
                    <![CDATA[Spacing on top, left, bottom, right. More details can be found <a href="https://tailwindcss.com/docs/margin" target="_blank">here</a>. E.g. "mt-8 mb-8 mr-4 ml-4". Multiple entries allowed according to tailwind standards.]]></description>
            </parameter>

        </parameters>
    </widget>


