<script>
    function amXsearchFaq() {
        return {
            faqItems() {
                return this.sections.faq.items
            },
            faqItemUrl() {
                return window.BASE_URL + this.item.url
            },
            faqItemName() {
                return this.item.name
            },
            faqTitle() {
                return this.sections.faq.title
            }
        }
    }
</script>
