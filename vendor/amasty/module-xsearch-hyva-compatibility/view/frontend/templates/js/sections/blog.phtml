<script>
    function amXsearchBlog() {
        return {
            blogItems() {
                return this.sections.blog.items
            },
            blogItemUrl() {
                return window.BASE_URL + this.item.url
            },
            blogItemTitle() {
                return this.item.title
            },
            blogItemDescription() {
                return this.item.description
            },
            blogTitle() {
                return this.sections.blog.title
            }
        }
    }
</script>
