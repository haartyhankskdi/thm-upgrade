<script>
    function amXsearchPages() {
        return {
            pageItems() {
                return this.sections.page.items
            },
            pageItemUrl() {
                return `${BASE_URL + this.item.url}`
            },
            itemTitle() {
                return this.item.title
            },
            itemDescription() {
                return this.item.description
            },
            pageTitle() {
                return this.sections.page.title
            }
        }
    }
</script>
