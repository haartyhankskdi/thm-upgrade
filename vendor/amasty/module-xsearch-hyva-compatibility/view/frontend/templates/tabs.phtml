declare(strict_types=1);

use Magento\Framework\Escaper;
use Amasty\Xsearch\Block\Search\Tab;

// phpcs:disable Generic.Files.LineLength.TooLong

/** @var Escaper $escaper */
/** @var Tab $block */

$collection = $block->getTabs();
?>

<?php if ($block->isTabsEnabled()): ?>
    <?= $block->getChildHtml('search-tabs-init') ?>
    <?php if ($collection): ?>
        <?php $searchResultHtml = $block->getChildHtml('search.result') ?>
        <div x-data="initTabs" x-init="changeTab" class="amtabs-wrapper">
            <div class="amtitles flex w-full flex-col md:flex-row" role="tablist">
                <button type="button"
                        role="tab"
                        class="amtitle active block md:flex flex-1 justify-start md:justify-center items-center text-base
                font-normal border rounded-md shadow-sm p-2 bg-gray-100 text-gray-800 cursor-pointer relative"
                        data-id="tabs_amasty_search_products_tab">
                    <span class="mr-1 pointer-events-none">
                        <?= $escaper->escapeHtml(__('Products')) ?>
                    </span>
                    <span class="amsearch-results-count mr-4 md:mr-0 pointer-events-none">
                        (<?= $escaper->escapeHtmlAttr($block->getProductCount())?>)
                    </span>
                    <span class="amsearch-results-icon rotate-90 absolute right-1 md:hidden pointer-events-none">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                             class="w-5 h-5" width="25" height="25">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7">
                            </path>
                        </svg>
                    </span>
                </button>
                <?php $itemsCount = count($collection) ?>
                <?php foreach ($collection as $key => $item): ?>
