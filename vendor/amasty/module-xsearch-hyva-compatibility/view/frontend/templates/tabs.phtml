                        <span class="mr-1 pointer-events-none">
                            <?= $escaper->escapeHtmlAttr($item['name']) ?>
                        </span>
                        <span class="amsearch-results-count mr-4 md:mr-0 pointer-events-none">
                            (<?= $escaper->escapeHtmlAttr($item['items_count']) ?>)
                        </span>
                        <span class="amsearch-results-icon rotate-90 absolute right-1 pointer-events-none md:hidden">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
