<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <type name="Hyva\CompatModuleFallback\Model\CompatModuleRegistry">
        <arguments>
            <argument name="compatModules" xsi:type="array">
                <item name="hyva-magento2-amasty-gdprcookie2" xsi:type="array">
                    <item name="original_module" xsi:type="string">Amasty_GdprCookie</item>
                    <item name="compat_module" xsi:type="string">Amasty_GdprCookieHyva</item>
                </item>
            </argument>
        </arguments>
    </type>
    <type name="Amasty\GdprCookieHyva\Model\Layout\CookieBarLayoutResolver">
        <arguments>
            <argument name="layoutHandlerMap" xsi:type="array">
                <!-- name is the value for cookie_bar_customisation/cookies_bar_style config -->
                <item name="0" xsi:type="string">hyva_amcookiebar_classic</item>
                <item name="1" xsi:type="string">hyva_amcookiebar_sidebar</item>
                <item name="2" xsi:type="string">hyva_amcookiebar_popup</item>
            </argument>
        </arguments>
    </type>
</config>
