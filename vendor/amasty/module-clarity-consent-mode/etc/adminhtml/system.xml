<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <section id="amasty_gdprcookie">
            <group id="clarity_consent_mode">
                <field id="clarity_consent_types" translate="label comment" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Consent Types</label>
                    <frontend_model>Amasty\ClarityConsentMode\Block\Adminhtml\System\Config\Form\Field\ConsentTypes</frontend_model>
                    <backend_model>Amasty\ClarityConsentMode\Model\Config\Backend\Serialized\ConsentTypesArraySerialized</backend_model>
                    <comment><![CDATA[More information on how Microsoft Clarity handles consent signals can be found <a href="https://learn.microsoft.com/en-us/clarity/setup-and-installation/consent-management#consent-state-and-clarity-behavior" target="_blank">here</a>.]]></comment>
                    <depends>
                        <field id="enable">1</field>
                    </depends>
                </field>
            </group>
        </section>
    </system>
</config>
